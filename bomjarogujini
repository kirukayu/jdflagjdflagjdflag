-- ============================================================
-- Ragdoll detection (for PFSwap perfect timing)
-- ============================================================

local function isRagdollHumanoid(hum)
    if not hum or hum.Health <= 0 then return false end
    local okAuto, auto = pcall(function() return hum.AutoRotate end)
    local okPlat, plat = pcall(function() return hum.PlatformStand end)
    if okAuto and auto == false then return true end
    if okPlat and plat == true then return true end
    return false
end

local function getRagdollTargetHumanoid()
    local root = LocalPlayer.Character
        and (LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            or LocalPlayer.Character.PrimaryPart)

    if not Camera and not root then return nil end

    local camPos = Camera and Camera.CFrame.Position
    local camLook = Camera and Camera.CFrame.LookVector

    local bestHumanoid = nil
    local bestScore = nil

    local function considerCharacter(char)
        if not char or char == LocalPlayer.Character then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        if not isRagdollHumanoid(hum) then return end

        local hrp = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
        if not hrp then return end

        local dist = root and (root.Position - hrp.Position).Magnitude or 9999
        if dist > 30 then return end

        local toTarget = camPos and camLook and (hrp.Position - camPos).Unit or Vector3.new()
        local facing = camLook and camLook:Dot(toTarget) or 0
        local score = dist * (2 - facing)

        if not bestScore or score < bestScore then
            bestScore = score
            bestHumanoid = hum
        end
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            considerCharacter(plr.Character)
        end
    end

    local charsFolder = workspace:FindFirstChild("Characters")
    if charsFolder then
        for _, c in ipairs(charsFolder:GetChildren()) do
            considerCharacter(c)
        end
    end

    local dummiesFolder = workspace:FindFirstChild("Dummies") or workspace:FindFirstChild("TrainingDummies")
    if dummiesFolder then
        for _, c in ipairs(dummiesFolder:GetChildren()) do
            considerCharacter(c)
        end
    end

    return bestHumanoid
end

-- ============================================================
-- Find nearest enemy (for BF Chain)
-- ============================================================

local function findNearestEnemy()
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart") or myChar.PrimaryPart
    if not myRoot then return nil end

    local myPos = myRoot.Position
    local camCF = Camera.CFrame
    local camPos = camCF.Position
    local camLook = camCF.LookVector
    local maxDist = 15
    local minDist = 2
    local candidates = {}

    local function consider(char)
        if not char or char == myChar then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        local hrp = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
        if not hrp then return end
        local pos = hrp.Position
        local dist = (pos - myPos).Magnitude
        if dist < minDist or dist > maxDist then return end
        local toTarget = (pos - camPos).Unit
        local facing = camLook:Dot(toTarget)
        if facing < 0.3 then return end
        table.insert(candidates, {
            char = char, hrp = hrp, dist = dist,
            facing = facing, score = dist * (2 - facing)
        })
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            consider(plr.Character)
        end
    end

    local charsFolder = workspace:FindFirstChild("Characters")
    if charsFolder then
        for _, c in ipairs(charsFolder:GetChildren()) do consider(c) end
    end

    local dummiesFolder = workspace:FindFirstChild("Dummies") or workspace:FindFirstChild("TrainingDummies")
    if dummiesFolder then
        for _, c in ipairs(dummiesFolder:GetChildren()) do consider(c) end
    end

    table.sort(candidates, function(a, b) return a.score < b.score end)
    return #candidates > 0 and candidates[1].char or nil
end

-- ============================================================
-- Behind-target check (for BF Chain)
-- ============================================================

local function isBehindTarget(targetHRP, myRoot)
    if not targetHRP or not myRoot then return false, 1 end
    local look = targetHRP.CFrame.LookVector
    local toMe = myRoot.Position - targetHRP.Position
    local hLook = Vector3.new(look.X, 0, look.Z)
    local hToMe = Vector3.new(toMe.X, 0, toMe.Z)
    if hLook.Magnitude < 0.001 or hToMe.Magnitude < 0.001 then return false, 1 end
    hLook = hLook.Unit
    hToMe = hToMe.Unit
    local dotFront = hLook:Dot(hToMe)
    return dotFront <= -0.4, dotFront
end

