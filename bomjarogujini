})

create_connection(iy_fly_element["on_toggle_change"], function(value)
    fly_settings.Enabled = value
    if value then
        sFLY()
    else
        NOFLY()
    end
end)

create_connection(iy_fly_speed_slider["on_slider_change"], function(value)
