        local skipFolders = {["Misc"] = true, ["Movement"] = true, ["Idle"] = true}
        
        for _, charFolder in ipairs(animsObj:GetChildren()) do
            -- Skip root-level Misc/Movement folders
            if skipFolders[charFolder.Name] then continue end
            
            for _, obj in ipairs(charFolder:GetDescendants()) do
                if obj:IsA("Animation") then
                    -- Check if any parent folder is Misc or Movement
                    local skip = false
                    local parent = obj.Parent
                    while parent and parent ~= charFolder do
                        if skipFolders[parent.Name] then
                            skip = true
                            break
                        end
                        -- Blacklist specifically Mechamaru.Absolute.Melee folder
                        if parent.Name == "Melee" and parent.Parent and parent.Parent.Name == "Absolute" then
                            skip = true
                            break
                        end
                        -- Blacklist specifically Mechamaru.Offloads folder
                        if parent.Name == "Offloads" and charFolder.Name == "Mechamaru" then
                            skip = true
                            break
                        end
                        -- Blacklist specifically Megumi.Mahoraga folder (and all its subfolders)
                        if parent.Name == "Mahoraga" and charFolder.Name == "Megumi" then
                            skip = true
                            break
                        end
                        -- Blacklist specifically Nanami.RatioBreaker folder
                        if parent.Name == "RatioBreaker" and charFolder.Name == "Nanami" then
                            skip = true
                            break
                        end
                        -- Blacklist specifically Yuta.Rika folder (and all its subfolders)
                        if parent.Name == "Rika" and charFolder.Name == "Yuta" then
                            skip = true
                            break
                        end
                        parent = parent.Parent
                    end
                    
                    if not skip then
                        local name = obj.Name:lower()
                        local bad = false
                        for _, word in ipairs(blacklist) do
                            -- Protected against accidental empty strings in blacklist array which nuke the string checker
                            if #word > 0 and string.find(name, word) then
                                bad = true
                                break
                            end
                        end
                        
                        if not bad or name:find("fourarmed") then
                            attackAnimations[obj.AnimationId] = name
                        end
                    end
                end
            end
        end
    end
end

local function buildNoBlockAnimations()
    table.clear(noBlockAnimations)
    local animsObj = game:GetService("ReplicatedStorage"):FindFirstChild("Animations")
    if not animsObj then return end
    
    local blacklist = {"idle", "sacrileg"}
    local skipFolders = {["Misc"] = true, ["Movement"] = true, ["Idle"] = true}
    
    for _, charFolder in ipairs(animsObj:GetChildren()) do
        if skipFolders[charFolder.Name] then continue end
        
        for _, obj in ipairs(charFolder:GetDescendants()) do
            if obj:IsA("Animation") then
                local skip = false
                local parent = obj.Parent
                while parent and parent ~= charFolder do
                    if skipFolders[parent.Name] then
                        skip = true
                        break
                    end
                    parent = parent.Parent
                end
                
                if not skip then
                    local cLower = charFolder.Name:lower()
                    local mLower = obj.Name:lower()
                    
                    if string.find(mLower, "chase") and AutoBlock.MoveBlacklist["All/Chase"] then
                        noBlockAnimations[obj.AnimationId] = true
                    end
                    
                    if not skip and string.find(cLower, "charles") then
                        if string.find(mLower, "despair") and AutoBlock.MoveBlacklist["Charles/Despair"] then
                            local nid = tostring(obj.AnimationId):match("%d+")
                            if not (nid and holdBlockAnimIds["rbxassetid://" .. nid]) then
                                noBlockAnimations[obj.AnimationId] = true
                            end
                        elseif string.find(mLower, "shutup") then
                            if string.find(mLower, "victim") and AutoBlock.MoveBlacklist["Charles/ShutUpVictim"] then
                                noBlockAnimations[obj.AnimationId] = true
                            elseif not string.find(mLower, "victim") and AutoBlock.MoveBlacklist["Charles/ShutUp"] then
                                noBlockAnimations[obj.AnimationId] = true
                            end
                        end
                    elseif not skip and string.find(cLower, "hakari") then
                        if string.find(mLower, "rough") and AutoBlock.MoveBlacklist["Hakari/RoughEnergy"] then
                            noBlockAnimations[obj.AnimationId] = true
                        end
                    elseif not skip and (string.find(cLower, "higuruma") or string.find(cLower, "hiromi")) then
                        if string.find(mLower, "judge") and AutoBlock.MoveBlacklist["Higuruma/JudgeReach"] then
                            noBlockAnimations[obj.AnimationId] = true
                        end
                    elseif not skip and string.find(cLower, "meimei") then
                        if mLower == "melee4" then
                            noBlockAnimations[obj.AnimationId] = true
                        end
                    end

                end
            end
        end
    end
end

