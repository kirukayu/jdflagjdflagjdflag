    return ok and val or 0
end

local function getEffectiveDelay()
    local d = (AutoBF.BaseDelay or 340) + (AutoBF.ManualOffset or 0)
    if AutoBF.PingAdjust then
        d = d - getPingMs()
    end
    return math.clamp(d, 30, 1000)
end

local function getPFSDelaySec(usePerfect)
    if usePerfect then
        local ping = (AutoPFSwap.PingAdjust and getPingMs() or 0)
        local base = (AutoPFSwap.PerfectBase or 350) - ping
        base = math.clamp(base, 50, 2000)
        return base / 1000
    end
    local d = AutoPFSwap.BaseDelay + AutoPFSwap.ManualOffset
    d = math.clamp(d, 50, 2000)
    return d / 1000
end

