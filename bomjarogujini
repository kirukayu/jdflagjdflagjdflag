-- W-key freeze fix: when Roblox window loses focus VIM drops all held keys.
-- Release W on focus loss so state stays in sync, re-send on return.
do
    local UIS_focus = cloneref(game:GetService("UserInputService"))
    UIS_focus.WindowFocusReleased:Connect(function()
        if AutoFarm._wHeld then
            -- Don't flip the flag — holdW will re-send on next Heartbeat after focus returns
            pcall(function() VIM:SendKeyEvent(false, Enum.KeyCode.W, false, game) end)
        end
    end)
    UIS_focus.WindowFocused:Connect(function()
        if AutoFarm.Enabled and AutoFarm._wHeld then
            -- Immediately re-press W so movement resumes without user touching the keyboard
            task.defer(function()
                pcall(function() VIM:SendKeyEvent(true, Enum.KeyCode.W, false, game) end)
            end)
        end
    end)
end

local function getAFNearestTarget()
    local nearest = nil
    local dist = math.huge
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local eHRP = plr.Character:FindFirstChild("HumanoidRootPart")
            local eHum = plr.Character:FindFirstChild("Humanoid")
            if eHRP and eHum and eHum.Health > 0 then
                local d = (eHRP.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    nearest = plr.Character
                end
            end
        end
    end
    return nearest
end

local function AF_Loop()
    if not AutoFarm.Enabled then
        if AutoFarm._wHeld then
            VIM:SendKeyEvent(false, Enum.KeyCode.W, false, game)
            AutoFarm._wHeld = false
        end
        return
    end

    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then return end
    
    -- Reactive Dodge + Retarget-on-Hit
    if not AutoFarm._dodgeConn or AutoFarm._dodgeChar ~= char then
        if AutoFarm._dodgeConn then pcall(function() AutoFarm._dodgeConn:Disconnect() end) end
        AutoFarm._dodgeChar = char
        AutoFarm._lastHP = hum.Health
        AutoFarm._dodgeConn = hum.HealthChanged:Connect(function(newHP)
            if not AutoFarm.Enabled then
                AutoFarm._lastHP = newHP
                return
            end
            
            if newHP < (AutoFarm._lastHP or 100) then
                -- Retarget: find who hit us (nearest enemy within 20 studs)
                local myHRP = char:FindFirstChild("HumanoidRootPart")
                if myHRP then
                    local closestDist = 20
                    local attacker = nil
                    for _, plr in ipairs(Players:GetPlayers()) do
                        if plr ~= LocalPlayer and plr.Character then
                            local eHRP = plr.Character:FindFirstChild("HumanoidRootPart")
                            local eHum = plr.Character:FindFirstChildOfClass("Humanoid")
                            if eHRP and eHum and eHum.Health > 0 then
                                local d = (eHRP.Position - myHRP.Position).Magnitude
                                if d < closestDist then
                                    closestDist = d
                                    attacker = plr.Character
                                end
                            end
                        end
                    end
                    if attacker and attacker ~= AutoFarm._stickyTarget then
                        AutoFarm._stickyTarget = attacker
                        AutoFarm._comboPattern = nil
                        AutoFarm._comboStep = 1
                        AutoFarm._comboM1 = 0
                    end
                end
                
                -- Reactive dodge
                if AutoFarm._inCombat then
                    if tick() - (AutoFarm._lastDodge or 0) > 6 then
                        AutoFarm._lastDodge = tick()
                        local dirs = {"Left", "Right", "Back"}
                        task.spawn(AF_NativeDash, dirs[math.random(1, 3)])
                    end
                end
            end
            AutoFarm._lastHP = newHP
        end)
    end
    
    -- Anti-Combo-Breaker: reset combo if we get stunned
    local info = char:FindFirstChild("Info")
    if info and info:FindFirstChild("Stun") then
        AutoFarm._comboPattern = nil
        AutoFarm._comboStep = 1
        AutoFarm._comboM1 = 0
    end
    
    -- Sticky Target: keep current target until IT dies or WE die
    local target = AutoFarm._stickyTarget
    if target then
        local still_valid = target.Parent 
            and target:FindFirstChild("HumanoidRootPart")
            and target:FindFirstChildOfClass("Humanoid")
            and target:FindFirstChildOfClass("Humanoid").Health > 0
        if not still_valid then
            -- Kill detected: track it for webhook
            if target:FindFirstChildOfClass("Humanoid") and target:FindFirstChildOfClass("Humanoid").Health <= 0 then
                local killTime = tick() - (AutoFarm._fightStart or tick())
                local victimName = "Unknown"
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr.Character == target then
                        victimName = plr.DisplayName .. " (@" .. plr.Name .. ")"
                        break
                    end
                end
                AutoFarm._lastKill = {
                    victim = victimName,
                    duration = killTime,
                    timestamp = os.time(),
                }
                AutoFarm._kills = (AutoFarm._kills or 0) + 1
                
                -- Webhook send
                if AutoFarm.WebhookURL and AutoFarm.WebhookURL ~= "" then
                    task.spawn(function()
                        pcall(function()
                            local timeStr
                            if killTime < 60 then
                                timeStr = string.format("%.1fs", killTime)
                            else
                                timeStr = string.format("%dm %ds", math.floor(killTime / 60), math.floor(killTime % 60))
                            end
                            
                            local myName = string.lower(LocalPlayer.DisplayName or LocalPlayer.Name)
                            
                            local embed = {
                                ["embeds"] = {{
                                    ["title"] = "\xe2\x98\x85 kill confirmed",
                                    ["description"] = "eliminated **" .. string.lower(victimName) .. "** in **" .. timeStr .. "**",
                                    ["color"] = 0x2B2D31,
                                    ["footer"] = {
                                        ["text"] = tostring(AutoFarm._kills) .. " total kills \xe2\x80\xa2 " .. myName .. " \xe2\x80\xa2 " .. os.date("%H:%M:%S")
                                    },
                                }},
                            }
                            
                            local HttpService = cloneref(game:GetService("HttpService"))
                            local json = HttpService:JSONEncode(embed)
                            
                            local req = (syn and syn.request) or (http and http.request) or http_request or request or fluxus and fluxus.request
                            if req then
                                req({
                                    Url = AutoFarm.WebhookURL,
                                    Method = "POST",
                                    Headers = {["Content-Type"] = "application/json"},
                                    Body = json
                                })
                            end
                        end)
                    end)
                end
            end
            target = nil
            AutoFarm._stickyTarget = nil
            AutoFarm._fightStart = nil
        end
    end
    if not target then
        target = getAFNearestTarget()
        AutoFarm._stickyTarget = target
        AutoFarm._fightStart = tick()
    end
    AutoFarm._target = target 
    
    if not AutoFarm._controls then
        pcall(function()
            AutoFarm._controls = require(LocalPlayer.PlayerScripts:WaitForChild("PlayerModule")):GetControls()
        end)
    end
    local Controls = AutoFarm._controls
    
    local function releaseW()
        if AutoFarm._wHeld then
            VIM:SendKeyEvent(false, Enum.KeyCode.W, false, game)
            AutoFarm._wHeld = false
        end
        if Controls then pcall(function() Controls:Move(Vector3.zero) end) end
    end

    local function holdW()
        -- Always resend — VIM ignores duplicate key-downs, but it ensures
        -- the key stays registered after focus loss/return or skill key presses.
        VIM:SendKeyEvent(true, Enum.KeyCode.W, false, game)
        AutoFarm._wHeld = true
        if Controls then pcall(function() Controls:Move(Vector3.new(0, 0, -1)) end) end
    end

    if not target then
        releaseW()
        return 
    end
    
    local tHRP = target:FindFirstChild("HumanoidRootPart")
    local tHum = target:FindFirstChildOfClass("Humanoid")
    if not tHRP or not tHum or tHum.Health <= 0 then 
        AutoFarm._stickyTarget = nil
        releaseW()
        return 
    end
    
    local dist = (hrp.Position - tHRP.Position).Magnitude
    
    
    -- ========== COMBAT ==========
    local engDist = AutoFarm.EngagementDist or 15
    if dist <= engDist then
        releaseW()
        AutoFarm._inCombat = true
        AutoFarm._combatTarget = target
        AutoFarm._camLook = nil  -- clear pathfinding look direction so it doesn't override LockOn
        
        -- Activate the existing LockOn system on the target only
        if LockOn then
            LockOn.Target = target
            if not LockOn.Active then
                LockOn.Active = true
            end
        end
        
        -- AutoBlock + AutoPunch Blatant
        local ab = AutoFarm._ab
        if ab then
            ab.Enabled = true
            ab.AutoPunch = true
            ab.PunchMode = "Blatant"
        end
        
        -- Auto-Ultimate (G): counter when bar is full and enemy is attacking
        local myInfo = char:FindFirstChild("Info")
        local ultCharge = LocalPlayer:GetAttribute("Ultimate") or 0
        local inUlt = char:GetAttribute("InUlt")
        local isStunned = myInfo and myInfo:FindFirstChild("Stun")
        local isRagdoll = (char:GetAttribute("Ragdoll") or 0) > 0
        
        if ultCharge >= 100 and not inUlt and not isStunned and not isRagdoll then
            local enemyInfo = target:FindFirstChild("Info")
            local enemyIsAttacking = enemyInfo and not enemyInfo:FindFirstChild("Block") and not enemyInfo:FindFirstChild("Stun")
            if enemyIsAttacking and dist < 10 and tick() - (AutoFarm._lastUlt or 0) > 5 then
                AutoFarm._lastUlt = tick()
                task.spawn(function()
                    pcall(function()
                        local moveset = char:GetAttribute("Moveset")
                        if not moveset then return end
                        local Knit = require(game.ReplicatedStorage.Knit.Knit)
                        local svc = Knit.GetService(moveset .. "Service")
                        if svc and svc.Ultimate then
                            svc.Ultimate:Fire()
                            task.wait(0.8)
                            if svc.Deultimate then
                                svc.Deultimate:Fire()
                            end
                        end
                    end)
                end)
            end
        end
        
        -- ====== GODMODE COMBO SYSTEM ======
        -- Situational intelligence: check enemy state
        local enemyBlocking = false
        local enemyStunned = false
        local enemyInFrame = false
        pcall(function()
            local tInfo = target:FindFirstChild("Info")
            if tInfo then
                enemyBlocking = tInfo:FindFirstChild("Block") ~= nil
                enemyStunned = tInfo:FindFirstChild("Stun") ~= nil
                enemyInFrame = tInfo:FindFirstChild("NaoyaFrame") ~= nil
            end
        end)
        
        -- Pattern pools by situation
        local comboPatterns
        if enemyInFrame then
            -- NAOYA NUKE: enemy is in glass frame → S4 priority, S1 secondary (x2-x3 damage)
            AutoFarm._comboPattern = nil  -- force new pattern immediately
            comboPatterns = {
                {w = 35, p = {"S4", "D"}},                               -- instant S4 nuke
                {w = 25, p = {"S4", "S1", "D"}},                         -- S4 → S1 double nuke
                {w = 20, p = {"S1", "S4", "D"}},                         -- S1 → S4
                {w = 10, p = {"S4", "S2", "S1", "D"}},                   -- triple skill nuke
                {w = 10, p = {"S4", "S3", "S1", "D"}},                   -- S4 → S3 → S1
            }
        elseif enemyBlocking then
            -- Enemy blocking → S2 blockbreak priority
            comboPatterns = {
                {w = 35, p = {3, "S2", "D"}},
                {w = 25, p = {"S3", 3, "S2", "D"}},
                {w = 20, p = {3, "S2", "D", 3, "S2", "D"}},
                {w = 10, p = {"S2", "D", 3, "S2", "D"}},
                {w = 10, p = {2, "S2", "S1", "D"}},
            }
        elseif enemyStunned then
            -- Enemy stunned → pure M1 + skill spam (max dmg)
            comboPatterns = {
                {w = 25, p = {3, "S1", 3, "S2", "D"}},
                {w = 25, p = {3, "S4", 3, "S2", "D"}},
                {w = 25, p = {3, "S2", 3, "S4", "D"}},
                {w = 25, p = {3, "S1", 3, "S4", "D"}},
            }
        else
            -- Normal: 3 M1 + skill focused, ALL skills
            comboPatterns = {
                {w = 15, p = {3, "S2", "D"}},                         -- 3M1 → 2 → dash
                {w = 13, p = {3, "S4", "D"}},                         -- 3M1 → 4 → dash
                {w = 12, p = {3, "S1", "D"}},                         -- 3M1 → 1 → dash
                {w = 8,  p = {3, "S3", "D"}},                         -- 3M1 → 3 → dash
                {w = 15, p = {"S3", 3, "S2", "D"}},                   -- KILLER: 3spam → 3M1 → 2 → dash
                {w = 10, p = {3, "S2", "D", 3, "S4", "D"}},           -- 3M1→2→dash→3M1→4→dash
                {w = 10, p = {3, "S4", "D", 3, "S2", "D"}},           -- 3M1→4→dash→3M1→2→dash
                {w = 7,  p = {3, "S1", "S2", "D"}},                   -- 3M1 → 1 → 2 → dash (double skill)
                {w = 5,  p = {3, "S4", "S1", "D"}},                   -- 3M1 → 4 → 1 → dash (double skill)
                {w = 5,  p = {"S3", 3, "S2", "D", 3, "S4", "D"}},    -- long: 3spam→3M1→2→dash→3M1→4→dash
            }
        end
        
        local skillMap = {
            ["S1"] = {enum = Enum.KeyCode.One,   vk = 0x31},
            ["S2"] = {enum = Enum.KeyCode.Two,   vk = 0x32},
            ["S3"] = {enum = Enum.KeyCode.Three, vk = 0x33},
            ["S4"] = {enum = Enum.KeyCode.Four,  vk = 0x34},
        }
        
        -- Pick combo pattern
        if not AutoFarm._comboPattern then
            local totalW = 0
            for _, cp in ipairs(comboPatterns) do totalW = totalW + cp.w end
            local roll = math.random() * totalW
            local acc = 0
            for _, cp in ipairs(comboPatterns) do
                acc = acc + cp.w
                if roll <= acc then
                    AutoFarm._comboPattern = cp.p
                    AutoFarm._comboStep = 1
                    AutoFarm._comboM1 = 0
                    break
                end
            end
        end
        
        local pattern = AutoFarm._comboPattern
        local step = AutoFarm._comboStep or 1
        
        local now = tick()
        AutoFarm._lastAttack = AutoFarm._lastAttack or now
        -- Humanized speed: 0.13-0.23s base, with rare hesitation pauses
        local attackSpeed = 0.13 + math.random() * 0.10
        -- ~8% chance of a tiny human hesitation between actions
        if math.random() < 0.08 then
            attackSpeed = attackSpeed + math.random() * 0.15
        end
        
        -- Skills and dashes fire INSTANTLY (no speed gate)
        if pattern and step <= #pattern then
            local action = pattern[step]
            local isM1 = type(action) == "number"
            
            if isM1 then
                -- M1: use speed gate
                if now - AutoFarm._lastAttack > attackSpeed then
                    AutoFarm._lastAttack = now
                    AutoFarm._comboM1 = (AutoFarm._comboM1 or 0) + 1
                    
                    task.spawn(function()
                        pcall(function()
                            local char2 = LocalPlayer.Character
                            if not char2 then return end
                            local moveset2 = char2:GetAttribute("Moveset")
                            if not moveset2 then return end
                            local Knit = require(game.ReplicatedStorage.Knit.Knit)
                            local svc2 = Knit.GetService(moveset2 .. "Service")
                            if svc2 and svc2.Activated then
                                local isAir = char2.Humanoid.FloorMaterial == Enum.Material.Air
                                svc2.Activated:Fire(nil, isAir and "Down" or nil)
                            end
                        end)
                    end)
                    
                    if AutoFarm._comboM1 >= action then
                        AutoFarm._comboM1 = 0
                        AutoFarm._comboStep = step + 1
                    end
                end
            elseif skillMap[action] then
                -- Skills: INSTANT (no gate)
                local sk = skillMap[action]
                -- Capture current target HRP and frame state for the async task
                local _tHRP_snap = tHRP
                local _isFrameSkill = enemyInFrame and (action == "S4" or action == "S1")
                task.spawn(function()
                    -- Always face enemy before pressing the skill key
                    AF_FaceTarget(_tHRP_snap)
                    if action == "S3" then
                        local spamEnd = tick() + 1.5
                        while tick() < spamEnd do
                            AF_FaceTarget(_tHRP_snap)
                            pcall(function()
                                if keypress then keypress(sk.vk); task.wait(0.05); keyrelease(sk.vk) end
                            end)
                            VIM:SendKeyEvent(true, sk.enum, false, game)
                            task.wait(0.05)
                            VIM:SendKeyEvent(false, sk.enum, false, game)
                            task.wait(0.1)
                        end
                    else
                        pcall(function()
                            if keypress then keypress(sk.vk); task.wait(0.05); keyrelease(sk.vk) end
                        end)
                        VIM:SendKeyEvent(true, sk.enum, false, game)
                        task.wait(0.05)
                        VIM:SendKeyEvent(false, sk.enum, false, game)
                    end

                    -- NaoyaFrame fallback: if frame is still active after main skill,
                    -- enemy likely blocked or skill missed → dump M1 + S2 into them
                    if _isFrameSkill then
                        task.wait(0.15)
                        pcall(function()
                            local tInfo = _tHRP_snap.Parent and _tHRP_snap.Parent:FindFirstChild("Info")
                            local stillInFrame = tInfo and tInfo:FindFirstChild("NaoyaFrame")
                            if stillInFrame and _tHRP_snap.Parent then
                                AF_FaceTarget(_tHRP_snap)
                                -- 2 quick M1 clicks
                                local c = workspace.CurrentCamera
                                local mx = c and c.ViewportSize.X / 2 or 0
                                local my = c and c.ViewportSize.Y / 2 or 0
                                for _ = 1, 2 do
                                    VIM:SendMouseButtonEvent(mx, my, 0, true, game, 0)
                                    task.wait(0.05)
                                    VIM:SendMouseButtonEvent(mx, my, 0, false, game, 0)
                                    task.wait(0.1)
                                end
                                -- Follow up with S2 (blockbreak / heavy hit)
                                AF_FaceTarget(_tHRP_snap)
                                VIM:SendKeyEvent(true, Enum.KeyCode.Two, false, game)
                                task.wait(0.05)
                                VIM:SendKeyEvent(false, Enum.KeyCode.Two, false, game)
                            end
                        end)
                    end
                end)
                AutoFarm._comboStep = step + 1
                AutoFarm._lastAttack = now
            elseif action == "D" then
                -- Dashes: INSTANT
                local dashDir = (math.random() > 0.5) and "Left" or "Right"
                task.spawn(AF_NativeDash, dashDir)
                AutoFarm._comboStep = step + 1
                AutoFarm._lastAttack = now
            elseif action == "DB" then
                task.spawn(AF_NativeDash, "Back")
                AutoFarm._comboStep = step + 1
                AutoFarm._lastAttack = now
            end
        elseif pattern then
            AutoFarm._comboPattern = nil
        end
        
        -- Ambient side-dash (1-2s)
        if tick() - (AutoFarm._lastSideDash or 0) > (1.0 + math.random()) then
            AutoFarm._lastSideDash = tick()
            local dashDir = (math.random() > 0.5) and "Left" or "Right"
            task.spawn(AF_NativeDash, dashDir)
        end

        -- Air Combat: random jump + air-dash to confuse opponent
        if AutoFarm.AirCombat then
            -- Jump: ~15% chance per second (checked at Heartbeat rate, gated to ~2-5s intervals)
            if tick() - (AutoFarm._lastAirJump or 0) > (2.0 + math.random() * 3.0) then
                if math.random() < 0.5 then  -- 50% of windows actually fire
                    AutoFarm._lastAirJump = tick()
                    hum.Jump = true
                    -- After jumping, do an air-dash to the side
                    task.delay(0.15 + math.random() * 0.15, function()
                        local dir = (math.random() > 0.5) and "Left" or "Right"
                        task.spawn(AF_NativeDash, dir)
                        -- Occasionally double air-dash (35% chance)
                        if math.random() < 0.35 then
                            task.delay(0.18, function()
                                local dir2 = (math.random() > 0.5) and "Left" or "Right"
                                task.spawn(AF_NativeDash, dir2)
                            end)
                        end
                    end)
                end
            end
        end
        return
    end

    -- ========== OUT OF COMBAT ==========
    AutoFarm._inCombat = false
    AutoFarm._combatTarget = nil
    AutoFarm._comboPattern = nil
    if AutoFarm._ab then AutoFarm._ab.AutoPunch = false end
    if LockOn then LockOn.Active = false end
    AutoFarm._comboCount = 0

    -- Reset path when target changes
    if AutoFarm._lastTarget ~= target then
        AutoFarm._pathPoints = nil
        AutoFarm._lastPath = 0
        AutoFarm._lastTarget = target
    end

    -- Pathfinding: recompute every 0.6s, more lenient agent so it finds paths over obstacles
    if tick() - AutoFarm._lastPath > 0.6 then
        AutoFarm._lastPath = tick()
        task.spawn(function()
            pcall(function()
                local path = PathfindingService:CreatePath({
                    AgentRadius    = 1.5,   -- tighter radius = finds more paths
                    AgentHeight    = 5,
                    AgentCanJump   = true,
                    AgentJumpHeight = 7.2,  -- standard Roblox jump height
                    AgentMaxSlope  = 60,    -- steeper slopes allowed
                })
                path:ComputeAsync(hrp.Position, tHRP.Position)
                if path.Status == Enum.PathStatus.Success then
                    local wps = path:GetWaypoints()
                    if #wps >= 2 then
                        AutoFarm._pathPoints = wps
                        AutoFarm._pathIdx = 2
                        AutoFarm._pathFailed = false
                    end
                else
                    -- Pathfinding failed (e.g. no walkable path) → use direct walk fallback
                    AutoFarm._pathFailed = true
                    AutoFarm._pathPoints = nil
                end
            end)
        end)
    end

    -- Navigate along path
    if AutoFarm._pathPoints and AutoFarm._pathIdx <= #AutoFarm._pathPoints then
        local wp = AutoFarm._pathPoints[AutoFarm._pathIdx]
        AutoFarm._camLook = wp.Position
        holdW()

        -- Waypoint Jump (path says jump here)
        if wp.Action == Enum.PathWaypointAction.Jump then
            hum.Jump = true
        end

        -- Obstacle raycast: blocked at knee but clear above → jump
        if tick() - (AutoFarm._lastObstacleCheck or 0) > 0.15 then
            AutoFarm._lastObstacleCheck = tick()
            local moveDir = hum.MoveDirection
            if moveDir.Magnitude > 0.1 then
                local rp = RaycastParams.new()
                rp.FilterType = Enum.RaycastFilterType.Exclude
                rp.FilterDescendantsInstances = {char}
                local kneeHit = workspace:Raycast(hrp.Position - Vector3.new(0, 1.5, 0), moveDir.Unit * 3.5, rp)
                if kneeHit then
                    local headHit = workspace:Raycast(hrp.Position + Vector3.new(0, 2.5, 0), moveDir.Unit * 3.5, rp)
                    if not headHit then
                        hum.Jump = true
                    end
                end
            end
        end

        -- Stuck detection: hasn't moved 0.3 studs in 0.5s
        local movedDist = AutoFarm._lastPos and (hrp.Position - AutoFarm._lastPos).Magnitude or 99
        if movedDist < 0.3 then
            local stuckFor = tick() - (AutoFarm._stuckTime or tick())
            if stuckFor > 0.5 then
                -- First escape: jump + forward dash
                hum.Jump = true
                task.spawn(function()
                    pcall(function()
                        VIM:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
                        task.wait(0.08)
                        VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
                    end)
                end)
            end
            if stuckFor > 2.0 then
                -- Still stuck after 2s: side-dash to break out, invalidate path so it recomputes
                local goLeft = math.random() > 0.5
                task.spawn(function()
                    pcall(function()
                        local sideKey = goLeft and Enum.KeyCode.A or Enum.KeyCode.D
                        VIM:SendKeyEvent(true, sideKey, false, game)
                        task.wait(0.04)
                        VIM:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
                        task.wait(0.08)
                        VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
                        VIM:SendKeyEvent(false, sideKey, false, game)
                    end)
                end)
                AutoFarm._pathPoints = nil
                AutoFarm._lastPath = 0       -- force immediate recompute
                AutoFarm._stuckTime = tick() -- reset so we don't spam
            end
        else
            AutoFarm._stuckTime = tick()
        end
        AutoFarm._lastPos = hrp.Position

        -- Advance waypoint index when close enough
        if (hrp.Position - wp.Position).Magnitude < 4 then
            AutoFarm._pathIdx = AutoFarm._pathIdx + 1
        end

        -- Jump Zones: hardcoded positions where bot must jump to clear obstacles
        for _, jz in ipairs(AutoFarm.JumpZones) do
            if (hrp.Position - jz.pos).Magnitude <= jz.radius then
                hum.Jump = true
                break
            end
        end

        -- Forward Dash: VIM Q every 1.2-2s while approaching
        if AutoFarm.AutoDash and dist > 12 and tick() - (AutoFarm._lastFwdDash or 0) > (1.2 + math.random() * 0.8) then
            AutoFarm._lastFwdDash = tick()
            task.spawn(function()
                pcall(function()
                    VIM:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
                    task.wait(0.08)
                    VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
                end)
            end)
        end
    else
        -- Fallback: no valid path → walk directly toward target
        AutoFarm._camLook = tHRP.Position
        holdW()

        -- Jump periodically to hop over obstacles on direct path
        if tick() - (AutoFarm._lastFallbackJump or 0) > 0.8 then
            AutoFarm._lastFallbackJump = tick()
            local rp = RaycastParams.new()
            rp.FilterType = Enum.RaycastFilterType.Exclude
            rp.FilterDescendantsInstances = {char}
            local fwd = (tHRP.Position - hrp.Position).Unit
            local kneeHit = workspace:Raycast(hrp.Position - Vector3.new(0, 1.5, 0), fwd * 3.5, rp)
            if kneeHit then
                hum.Jump = true
            end
        end

        -- Forward Dash in fallback mode too
        if AutoFarm.AutoDash and dist > 12 and tick() - (AutoFarm._lastFwdDash or 0) > (1.5 + math.random() * 0.8) then
            AutoFarm._lastFwdDash = tick()
            task.spawn(function()
                pcall(function()
                    VIM:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
                    task.wait(0.08)
                    VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
                end)
            end)
        end
    end
end

game:GetService("RunService"):BindToRenderStep("AF_CamLock", Enum.RenderPriority.Camera.Value + 10, function()
    if not AutoFarm.Enabled then return end
    
    -- Keep existing LockOn system updated with the current combat target
    if AutoFarm._inCombat and AutoFarm._combatTarget then
        if LockOn then
            LockOn.Target = AutoFarm._combatTarget
            if not LockOn.Active then LockOn.Active = true end
        end
        return
    end
    
    -- PATHFINDING MODE: point camera toward waypoint so W goes in right direction
    if AutoFarm._camLook then
        local cam = workspace.CurrentCamera
        if not cam then return end
        local currentPos = cam.CFrame.Position
        local lookTarg = Vector3.new(AutoFarm._camLook.X, currentPos.Y, AutoFarm._camLook.Z)
        if (lookTarg - currentPos).Magnitude > 0.05 then
            cam.CFrame = CFrame.lookAt(currentPos, lookTarg)
        end
    end
end)
