-- ============================================================
-- Projectile Block Detector
-- Sets AutoBlock._projForceBlock = true when a projectile is
-- heading toward the player. The AutoBlock Heartbeat loop
-- reads this flag and manages block input automatically.
-- ============================================================
AutoBlock._projForceBlock = false
AutoBlock.ProjectileBlock = false

do
    -- Blockbreak moves — never block these
    local IGNORE_PROJ = {
        "HollowPurple", "BlackFlash", "Black Flash", "Divergent", "Idle", "Dash", "Blue",
    }
    local MIN_SPEED  = 20
    local BLOCK_DIST = 42
    local AIM_DOT    = 0.60
    local GRACE      = 0.25
    local _activeThreatCount = 0
    local _projGraceTarget   = 0

    local function isIgnored(name)
        for _, kw in ipairs(IGNORE_PROJ) do
            if name:find(kw, 1, true) then return true end
        end
        return false
    end


    local function watchProjectile(part)
        if isIgnored(part.Name) then return end
        local myChar = LocalPlayer.Character
        if myChar and part:IsDescendantOf(myChar) then return end

        local function checkOwner(p)
            if not p then return false end
            if p:GetAttribute("Player") == LocalPlayer.Name then return true end
            local c = p:GetAttribute("Creator")
            if c == LocalPlayer.Name or (myChar and c == myChar.Name) then return true end
            local o = p:FindFirstChild("creator") or p:FindFirstChild("Owner")
            if o and (o.Value == LocalPlayer or (myChar and o.Value == myChar)) then return true end
            return false
        end

        if checkOwner(part) or checkOwner(part.Parent) or checkOwner(part.Parent and part.Parent.Parent) then return end

        local isThreat = false
        local prevPos  = part.Position
        local prevTick = tick()
        local conn

        conn = game:GetService("RunService").Heartbeat:Connect(function()
            if not part.Parent or not AutoBlock.ProjectileBlock then
                if isThreat then
                    isThreat = false
                    _activeThreatCount = math.max(0, _activeThreatCount - 1)
                    local delayTime = GRACE
                    local n = part.Name
                    -- If it's destroyed (hit block), use a very short grace instead of 0.55s
                    if n:find("Bud") or n:find("Shot") then
                        delayTime = 0.25
                    end
                    _projGraceTarget = math.max(_projGraceTarget, tick() + delayTime)
                    task.delay(delayTime, function()
                        if _activeThreatCount <= 0 and tick() >= _projGraceTarget - 0.01 then
                            AutoBlock._projForceBlock = false
                        end
                    end)
                end
                conn:Disconnect()
                return
            end

            local mc  = LocalPlayer.Character
            local hrp = mc and mc:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            local curPos  = part.Position
            local toMe    = hrp.Position - curPos
            local dist    = toMe.Magnitude
            local physVel = part.AssemblyLinearVelocity
            local physSpd = physVel.Magnitude

            local now      = tick()
            local elapsed  = now - prevTick
            local deltaVel = elapsed > 0 and (curPos - prevPos) / elapsed or Vector3.zero
            local deltaSpd = deltaVel.Magnitude
            prevPos  = curPos
            prevTick = now

            local spd = math.max(physSpd, deltaSpd)
            local dir = physSpd >= deltaSpd and physVel.Unit or deltaVel.Unit

            local heading = spd >= MIN_SPEED
                and dist <= BLOCK_DIST
                and dist > 0.5
                and spd > 0
                and dir:Dot(toMe.Unit) >= AIM_DOT

            if heading and not isThreat then
                isThreat = true
                _activeThreatCount = _activeThreatCount + 1
                AutoBlock._projForceBlock = true
            elseif not heading and isThreat then
                isThreat = false
                _activeThreatCount = math.max(0, _activeThreatCount - 1)
                local delayTime = GRACE
                local n = part.Name
                -- For passing by, hold slightly longer but 0.55s was too much.
                if n:find("Bud") or n:find("Shot") then
                    delayTime = 0.35
                end
                _projGraceTarget = math.max(_projGraceTarget, tick() + delayTime)
                task.delay(delayTime, function()
                    if _activeThreatCount <= 0 and tick() >= _projGraceTarget - 0.01 then
                        AutoBlock._projForceBlock = false
                    end
                end)
            end
        end)

        table.insert(ab_conns, conn)
    end

    local function hookEffectsFolder(folder)
        local function onAdded(desc)
            if not AutoBlock.ProjectileBlock then return end
            
            if desc:IsA("BasePart") then
                local isLasso = string.find(desc:GetFullName(), "Lasso")
                if folder.Name == "Bullets" or desc:GetAttribute("Player") or isLasso then
                    task.spawn(watchProjectile, desc)
                end
            end
        end

        local conn = folder.DescendantAdded:Connect(onAdded)
        table.insert(ab_conns, conn)

        -- Initial scan for already existing objects
        for _, d in ipairs(folder:GetDescendants()) do
            task.spawn(onAdded, d)
        end
    end

    task.spawn(function()
        local FOLDERS = { "Bullets", "Effects", "Visuals", "Debris" }
        for _, name in ipairs(FOLDERS) do
            local folder = workspace:FindFirstChild(name)
                        or workspace:WaitForChild(name, 10)
            if folder then hookEffectsFolder(folder) end
        end
        workspace.ChildAdded:Connect(function(child)
            for _, name in ipairs(FOLDERS) do
                if child.Name == name then hookEffectsFolder(child) end
            end
        end)
    end)

end



-- ============================================================
-- Face Target (Direct CFrame — Zero Physics Delay)
-- Uses BindToRenderStep at LAST priority = runs after everything
-- No AlignOrientation, no constraints, no physics pipeline.
-- Pure CFrame override = absolute minimum possible latency.
-- ============================================================
pcall(function() game:GetService("RunService"):UnbindFromRenderStep("OBLV_FaceTarget") end)
if getgenv().OBLV_FT_Conn then pcall(function() getgenv().OBLV_FT_Conn:Disconnect() end) end

local _FT_LINGER = 0.30
local _ftLastSawTarget = 0

game:GetService("RunService"):BindToRenderStep("OBLV_FaceTarget", Enum.RenderPriority.Last.Value + 1, function()

    if not AutoBlock.Enabled or not AutoBlock.FaceTarget then
        if AutoBlock._ftActive then
            pcall(function()
                local myChar = LocalPlayer.Character
                if myChar then
                    local myHrp = myChar:FindFirstChild("HumanoidRootPart")
                    if myHrp then
                        local ao = myHrp:FindFirstChild("AB_FaceTargetAO")
                        if ao then ao:Destroy() end
                    end
                    local myHum = myChar:FindFirstChild("Humanoid")
                    if myHum then myHum.AutoRotate = true end
                    myChar:SetAttribute("AutoRotate", true)
                end
            end)
            AutoBlock._ftActive = false
        end
        _ftLastSawTarget = 0
        return
    end
    
    local lastHRP = _abInstant.lastHRP
    
    local animAttackActive = false
    for _, flag in pairs(_abInstant.flags) do
        if flag.tick and tick() - flag.tick < 1.5 then
            animAttackActive = true
            break
        end
    end

    local blockingNow = lastHRP and lastHRP.Parent and AutoBlock.CurrentlyBlocking and animAttackActive
    
    if blockingNow then
        _ftLastSawTarget = tick()
    end
    
    local withinLinger = (tick() - _ftLastSawTarget) < _FT_LINGER
    local hasTarget = lastHRP and lastHRP.Parent and withinLinger
    
    local myChar = LocalPlayer.Character
    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if hasTarget and myHrp then
        local myHum = myChar:FindFirstChild("Humanoid")
        if myHum then myHum.AutoRotate = false end
        pcall(function() myChar:SetAttribute("AutoRotate", false) end)
        
        local enemyPos = lastHRP.Position
        local vel = lastHRP.AssemblyLinearVelocity
        if vel and vel.Magnitude > 2 then
            enemyPos = enemyPos + Vector3.new(vel.X, 0, vel.Z) * 0.033
        end
        
        local myPos = myHrp.Position
        local flat = Vector3.new(enemyPos.X - myPos.X, 0, enemyPos.Z - myPos.Z)
        if flat.Magnitude > 0.1 then
            myHrp.CFrame = CFrame.lookAt(myPos, myPos + flat)
        end
        AutoBlock._ftActive = true
        
    elseif AutoBlock._ftActive then
        if myHrp then
            local ao = myHrp:FindFirstChild("AB_FaceTargetAO")
            if ao then ao:Destroy() end
        end
        if myChar then
            local myHum = myChar:FindFirstChild("Humanoid")
            if myHum then myHum.AutoRotate = true end
            pcall(function() myChar:SetAttribute("AutoRotate", true) end)
        end
        AutoBlock._ftActive = false
        _ftLastSawTarget = 0
    end
end)

-- ============================================================
-- Auto Punch: detect block-hit on OUR character, then counter M1
-- Block-hit reaction anims have Length ~0.3s across all characters
-- ============================================================
local function setupAutoPunchHook()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    local animator = hum:WaitForChild("Animator", 5)
    if not animator then return end

    local lastPunchTime = 0
    local punching = false

    local conn = animator.AnimationPlayed:Connect(function(track)
        local anim = track.Animation
        local animId = anim and anim.AnimationId
        local realId = getAssetId(animId)

        local isBlockHit = false
        if realId and blockHitAnimations[realId] then
            isBlockHit = true
        end
        local isNormalHit = false
        if realId and normalHitAnimations[realId] then
            isNormalHit = true
        end

        local hbs_nearby = false
        local detected_grace = nil
        if isBlockHit then
            pcall(function()
                local lpHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if lpHrp then
                    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
                        if p ~= LocalPlayer and p.Character then
                            local eHrp = p.Character:FindFirstChild("HumanoidRootPart")
                            if eHrp and (eHrp.Position - lpHrp.Position).Magnitude <= 45 then
                                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                                local animatorEnemy = hum and hum:FindFirstChildOfClass("Animator")
                                if animatorEnemy then
                                    for _, trk in ipairs(animatorEnemy:GetPlayingAnimationTracks()) do
                                        local trackId = trk.Animation and trk.Animation.AnimationId
                                        if trackId then
                                            local numId = tostring(trackId):match("%d+")
                                            if numId and holdBlockAnimIds["rbxassetid://" .. numId] then
                                                hbs_nearby = true
                                                detected_grace = holdBlockAnimGraces["rbxassetid://" .. numId]
                                                break
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        if hbs_nearby then break end
                    end
                end
            end)
        end

        if isBlockHit and AutoBlock.SoundBro then
            if not getgenv().OBLV_Audio_Bro_Ticks then getgenv().OBLV_Audio_Bro_Ticks = 0 end
            if tick() - getgenv().OBLV_Audio_Bro_Ticks > 0.3 then
                getgenv().OBLV_Audio_Bro_Ticks = tick()
                if getgenv().OBLV_Audio then
                    local rand = math.random(1, 4)
                    local sndName = (rand == 4) and "talking-ben-no" or "noben"
                    getgenv().OBLV_Audio.Play(sndName, 2.0)
                end
            end
        end

        if not AutoBlock.AutoPunch then return end

        if isBlockHit and hbs_nearby then
            -- МНОГОХИТОВЫЙ СКИЛЛ (DESPAIR И Т.Д.) -> РАБОТАЕМ ЧИСТО ПО ГРЕЙСУ
            AutoBlock._lastBlockHitTick = tick()
            local grace = type(detected_grace) == "number" and detected_grace or 0.20
            
            task.delay(grace, function()
                if AutoBlock._lastBlockHitTick and (tick() - AutoBlock._lastBlockHitTick) >= (grace - 0.03) then
                    -- Если нас больше не били по блоку в течении grace времени -> окно паниша!
                    if not punching then
                        if tick() - lastPunchTime < grace then return end
                        lastPunchTime = tick()
                        punching = true
                        
                        -- Даем кулдаун основному лупу сканирования, чтобы он не перебил снятие блока
                        -- 0.5s + 0.12s base = 0.62s of total AutoBlock silence to let M1 hit
                        AutoBlock._punchCooldown = tick() + 0.5
                        
                        pcall(function()
                            AutoBlock._hbs_active = false
                            AutoBlock.LastActiveAttack = 0
                            simulateBlockUp()
                            AutoBlock.CurrentlyBlocking = false
                            knitFireM1()
                            task.defer(function()
                                punching = false
                            end)
                        end)
                    end
                end
            end)
            return -- Остановка, ждем таймера!
        end

        -- ОБЫЧНЫЕ УДАРЫ ПО БЛОКУ (ИЛИ ПРОБИТИЕ) -> МГНОВЕННЫЙ ПАНИШ БЕЗ ДЕЛЕЕВ
        if (isBlockHit or isNormalHit) then
            if punching then return end
            if (tick() - lastPunchTime) < 0.1 then return end

            lastPunchTime = tick()
            punching = true

        task.spawn(function()
            local delayTime = 0
            if AutoBlock.PunchMode == "Legit" then
                delayTime = AutoBlock.PunchDelay + (math.random(0, 80) / 1000)
            end

            AutoBlock._punchCooldown = tick() + delayTime

            simulateBlockUp()
            AutoBlock.CurrentlyBlocking = false
            AutoBlock.LastActiveAttack = 0

            if delayTime > 0 then
                task.wait(delayTime)
            end

            -- Sleep autoblock so it doesn't interrupt us catching them
            AutoBlock._punchCooldown = tick() + 0.5
            AutoBlock._hbs_active = false
            AutoBlock.LastActiveAttack = 0
            
            simulateBlockUp()
            AutoBlock.CurrentlyBlocking = false
            
            knitFireM1()
            task.defer(function()
                punching = false
            end)
        end)
    end 
    end)
    table.insert(ab_conns, conn)
end

