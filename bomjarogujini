local function AF_NativeDash(direction)
    local char = LocalPlayer.Character
    if not char then return end

    if AutoFarm.DashMode == "Blatant" then
        -- Blatant: direct Knit remote, no cooldown check, works through stun
        pcall(function()
            if AF_KnitMoveService and AF_KnitMoveService.Dash then
                AF_KnitMoveService.Dash:Fire(direction)
            end
            if AF_KnitMoveController and AF_KnitMoveController.Dash then
                AF_KnitMoveController:Dash(LocalPlayer, char, direction)
            end
        end)
    else
        -- Legit: check game state, then simulate Q key (goes through DashRequest + cooldowns)
        local info = char:FindFirstChild("Info")
        if info then
            if info:FindFirstChild("Stun") then return end
            if info:FindFirstChild("Block") then return end
            if info:FindFirstChild("NoDash") then return end
        end
        if char:GetAttribute("Ragdoll") and char:GetAttribute("Ragdoll") > 0 then return end

        local dirKey
        if direction == "Left" then dirKey = Enum.KeyCode.A
        elseif direction == "Right" then dirKey = Enum.KeyCode.D
        elseif direction == "Back" then dirKey = Enum.KeyCode.S
        else dirKey = Enum.KeyCode.W end

        VIM:SendKeyEvent(true, dirKey, false, game)
        task.wait(0.05)
        VIM:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
        task.wait(0.1)
        VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
        VIM:SendKeyEvent(false, dirKey, false, game)
    end
end

-- Instantly snap HRP to face a target HRP (used before skill presses so they don't miss)
local function AF_FaceTarget(targetHRP)
    pcall(function()
        local myChar = LocalPlayer.Character
        if not myChar or not targetHRP or not targetHRP.Parent then return end
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        local flat = Vector3.new(
            targetHRP.Position.X - myHRP.Position.X,
            0,
            targetHRP.Position.Z - myHRP.Position.Z
        )
        if flat.Magnitude > 0.1 then
            myHRP.CFrame = CFrame.lookAt(myHRP.Position, myHRP.Position + flat)
            -- Also snap camera so skills that rely on camera direction connect
            local cam = workspace.CurrentCamera
            if cam then
                local camPos = cam.CFrame.Position
                local aimY = targetHRP.Position.Y
                cam.CFrame = CFrame.lookAt(camPos, Vector3.new(targetHRP.Position.X, aimY, targetHRP.Position.Z))
            end
        end
    end)
end

