    ["name"] = "Fly"
}, {
    ["toggle"] = { ["flag"] = "misc_iy_fly_final_v2" },
})

local iy_fly_settings_el = iy_fly_element:create_settings()
local iy_fly_speed_slider = iy_fly_settings_el:create_element({
