local function simulateBlockDown()
    pcall(function()
        local char = LocalPlayer.Character
        local target = char and AutoBlock.Enabled and _abInstant.lastHRP and _abInstant.lastHRP.Parent
        
        -- Priority: User's raw remote path (proven to work)
        local raw = game:GetService("ReplicatedStorage"):FindFirstChild("Knit")
        if raw and raw:FindFirstChild("Knit") and raw.Knit:FindFirstChild("Services") then
            local svc = raw.Knit.Services:FindFirstChild("BlockService")
            if svc and svc:FindFirstChild("RE") and svc.RE:FindFirstChild("Activated") then
                svc.RE.Activated:FireServer(target or nil)
                return
            end
        end

        -- Fallback: Existing proxy logic
        if _AB_BlockService and _AB_BlockService.Activated then
            if _AB_BlockService.Activated.FireServer then
                _AB_BlockService.Activated:FireServer(target or nil)
            else
                _AB_BlockService.Activated:Fire(target or nil)
            end
        end
    end)
end

local function simulateBlockUp()
    if AutoBlock._despairActive then return end
    pcall(function()
        -- Priority: User's raw remote path
        local raw = game:GetService("ReplicatedStorage"):FindFirstChild("Knit")
        if raw and raw:FindFirstChild("Knit") and raw.Knit:FindFirstChild("Services") then
            local svc = raw.Knit.Services:FindFirstChild("BlockService")
            if svc and svc:FindFirstChild("RE") and svc.RE:FindFirstChild("Deactivated") then
                svc.RE.Deactivated:FireServer()
                return
            end
        end

        -- Fallback: Existing proxy logic
        if _AB_BlockService and _AB_BlockService.Deactivated then
            if _AB_BlockService.Deactivated.FireServer then
                _AB_BlockService.Deactivated:FireServer()
            else
                _AB_BlockService.Deactivated:Fire()
            end
        end
    end)
end

