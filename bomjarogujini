            outline = true;
            type = "lower"; -- lower, HIGHER
            layout = "Center"; -- Center, Left, Right
            font = "Roboto" -- Default font
        };

        flags = {
            distance = {true, Color3.fromRGB(235, 235, 235)};
            tool = {true, Color3.fromRGB(235, 235, 235)};
            state = {true, Color3.fromRGB(235, 235, 235)};
        };

        health_bars = {
