    local _be_KnitMoveService
    pcall(function()
        local Knit = require(game.ReplicatedStorage.Knit.Knit)
        _be_KnitMoveService = Knit.GetService("MovementService")
    end)

    local NoStun = { Enabled = false }

    local function be_FireDash(dir)
        task.spawn(function()
            pcall(function()
                if _be_KnitMoveService then
                    _be_KnitMoveService.Dash:Fire(dir, true)
                end
            end)
        end)
    end

    RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local isDead = char:GetAttribute("Dead")
        if isDead then return end

        local myInfo = char:FindFirstChild("Info")
        local isRagdoll = (char:GetAttribute("Ragdoll") or 0) > 0
        local now = tick()

        -- No Stun: destroy stun values every frame
        if NoStun.Enabled and myInfo then
            local stunVal = myInfo:FindFirstChild("Stun")
            if stunVal then
                pcall(function() stunVal:Destroy() end)
            end
            pcall(function() char:SetAttribute("Stun", nil) end)
        end

        -- Auto Burst: escape enemy combos via remote
        if AutoBurst.Enabled then
            local isStunned = myInfo and myInfo:FindFirstChild("Stun")
            local hasBurst = char:GetAttribute("Burst")
            local inKnockback = myInfo and myInfo:FindFirstChild("Knockback")
            local forceEsc = myInfo and myInfo:FindFirstChild("ForceEsc")

            if (hasBurst or inKnockback or forceEsc) and (isStunned or isRagdoll or inKnockback or forceEsc) then
                if now - AutoBurst.LastBurstTick > AutoBurst.MinInterval then
                    AutoBurst.LastBurstTick = now
                    be_FireDash((math.random() > 0.5) and "Left" or "Right")
                end
            end
        end

        -- Auto Evade: wake from ragdoll via remote
        if AutoEvade.Enabled then
            local evadeCharge = char:GetAttribute("Evade") or 0

            if isRagdoll and evadeCharge > 0 then
                if now - AutoEvade.LastEvadeTick > AutoEvade.MinInterval then
                    AutoEvade.LastEvadeTick = now
                    be_FireDash((math.random() > 0.5) and "Left" or "Right")
                end
            end
        end
    end)

    local burst_el = combat_exploit_section:create_element({ name = "Auto Burst" }, {
        toggle = { flag = "exploit_auto_burst", default = false },
    })
    create_connection(burst_el["on_toggle_change"], function(state)
        AutoBurst.Enabled = state
    end)

    local evade_el = combat_exploit_section:create_element({ name = "Auto Evade" }, {
        toggle = { flag = "exploit_auto_evade", default = false },
    })
    create_connection(evade_el["on_toggle_change"], function(state)
        AutoEvade.Enabled = state
    end)

    local nostun_el = combat_exploit_section:create_element({ name = "No Stun" }, {
        toggle = { flag = "exploit_no_stun", default = false },
    })
    create_connection(nostun_el["on_toggle_change"], function(state)
        NoStun.Enabled = state
    end)

    combat_exploit_section:create_element({
        name = "burst = escape combo, evade = wake ragdoll",
        fake = true
    }, {})
end

print("[FINAL OBLIVION] Misc tab loaded")
