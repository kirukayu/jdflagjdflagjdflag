local function hookAnimatorInstant(char)
    if not char or _abInstant.hooked[char] then return end
    _abInstant.hooked[char] = true

    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local animator = hum:FindFirstChildOfClass("Animator")
        or hum:WaitForChild("Animator", 3)
    if not animator then return end

    local conn = animator.AnimationPlayed:Connect(function(track)
        local animId = track.Animation and track.Animation.AnimationId
        if not animId then return end
        local animName = attackAnimations[animId]
        if animName and not noBlockAnimations[animId] then
            if AutoBlock.Debug then
                print("[AutoBlock Debug] Block triggered by:", animName, "from", char.Name)
            end
            local numMatch = animId and tostring(animId):match("%d+")
            local holdSkillActive = holdBlockAnimIds[animId] or (numMatch and holdBlockAnimIds["rbxassetid://" .. numMatch]) or false
            
            _abInstant.flags[char] = {
                tick = tick(),
                animId = animId,
                track = track,
                isHoldSkill = holdSkillActive
            }
            
            _abInstant.lastHRP = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
        end
    end)
    table.insert(ab_conns, conn)

    char.AncestryChanged:Connect(function(_, parent)
        if not parent then
            _abInstant.hooked[char] = nil
            _abInstant.flags[char] = nil
        end
    end)
end

local function hookAllEnemyAnimators()
    local function tryHookPlayer(player)
        if player == LocalPlayer then return end
        local function onChar(c) task.defer(hookAnimatorInstant, c) end
        player.CharacterAdded:Connect(onChar)
        if player.Character then task.defer(onChar, player.Character) end
    end
    for _, p in ipairs(Players:GetPlayers()) do tryHookPlayer(p) end
    Players.PlayerAdded:Connect(tryHookPlayer)

    local function hookFolder(folder)
        if not folder then return end
        for _, c in ipairs(folder:GetChildren()) do
            if c ~= LocalPlayer.Character then
                task.defer(hookAnimatorInstant, c)
            end
        end
        folder.ChildAdded:Connect(function(c)
            task.defer(function()
                if c ~= LocalPlayer.Character then
                    hookAnimatorInstant(c)
                end
            end)
        end)
    end
    hookFolder(workspace:FindFirstChild("Characters"))
    hookFolder(workspace:FindFirstChild("Dummies") or workspace:FindFirstChild("TrainingDummies"))
end

local function setupAutoBlockHooks()
    local animsObj = game:GetService("ReplicatedStorage"):WaitForChild("Animations", 30)
    if not animsObj then
        warn("[AutoBlock] Animations folder failed to load!")
        return
    end

    buildHoldBlockAnims()
    buildAttackAnimations()
    buildNoBlockAnimations()
    buildDirectionalAnimations()
    buildSpamAnimations()
    buildBlockHitAnimations()
    buildNormalHitAnimations()
    setupEnemyHitListeners()
    setupLocalHakariDetector()
    buildLongBlockAnimations()
    hookAllEnemyAnimators()
    
    local rs_conn = game:GetService("RunService").RenderStepped:Connect(function()
        if not AutoBlock.Enabled and not AutoBlock.AutoPunch then
            if AutoBlock.CurrentlyBlocking then
                AutoBlock.CurrentlyBlocking = false
                simulateBlockUp()
            end
            return
        end
        
        local lpChar = LocalPlayer.Character
        local lpHrp = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
        if not lpHrp then return end

        local shouldBlock = false
        local lastAttackLength = 0
        local spinTargetPos = nil
        local attackerHRP = nil

        if AutoBlock._punchCooldown and (tick() - AutoBlock._punchCooldown) < 0.12 then
            return
        end
        
        -- Ping compensation (Based on Lycoris RakNet RTT formula)
        local recvPing = 0
        pcall(function()
            local dataPingItem = game:GetService("Stats").Network.ServerStatsItem:FindFirstChild("Data Ping")
            if dataPingItem then
                recvPing = math.max((dataPingItem:GetValue() / 1000) / 2, 0.0)
            end
        end)

        -- Unified character scanner: checks animation tracks + instant flags
        local function scanCharacter(char)
            if shouldBlock then return end
            if not char or char == lpChar then return end
            local hrp = char:FindFirstChild("HumanoidRootPart") or (char:FindFirstChildOfClass("Humanoid") and char.PrimaryPart)
            if not hrp then return end

            local dist = (hrp.Position - lpHrp.Position).Magnitude

            -- Velocity prediction: if enemy moves toward us, extend trigger distance
            local velBonus = 0
            pcall(function()
                local vel = hrp.AssemblyLinearVelocity or hrp.Velocity
                if vel then
                    local toMe = (lpHrp.Position - hrp.Position)
                    if toMe.Magnitude > 0.1 then
                        local closing = vel:Dot(toMe.Unit)
                        if closing > 5 then
                            velBonus = math.clamp(closing * 0.08, 0, 6)
                        end
                    end
                end
            end)

            local hum = char:FindFirstChildOfClass("Humanoid")
            local animator = hum and hum:FindFirstChildOfClass("Animator")
            
            -- IMMEDIATE OVERRIDE: If the enemy interrupts their attack with a Dash, or gets stunned/hit, ABORT.
            if animator then
                local isCancelled = false
                pcall(function()
                    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                        if track.IsPlaying then
                            local id = track.Animation and track.Animation.AnimationId
                            if id and type(id) == "string" then
                                local realId = getAssetId(id)
                                if noBlockAnimations[id] or (realId and (normalHitAnimations[realId] or blockHitAnimations[realId])) then
                                    isCancelled = true
                                    break
                                end
                            end
                        end
                    end
                end)
                
                if isCancelled then
                    _abInstant.flags[char] = nil -- nuke the ghost attack flag instantly
                    return -- do not block this cancelled character
                end
            end

            local flag = _abInstant.flags[char]
            if flag then
                local track = flag.track
                local elapsed = tick() - flag.tick
                local maxElapsed = flag.isHoldSkill and 10 or 1.5
                if track and typeof(track) == "Instance" and elapsed < maxElapsed then
                    local isPlaying = false
                    pcall(function() isPlaying = track.IsPlaying end)

                    if not isPlaying and elapsed > 0.05 then
                        if AutoBlock.Debug2 then
                            print("[AB Debug2] CLEARED flag (not playing) for", char.Name, "elapsed:", elapsed)
                        end
                        _abInstant.flags[char] = nil
                    elseif flag.isHoldSkill then
                        local validDist = 25 + velBonus
                        if AutoBlock.Debug2 then
                            print("[AB Debug2] HoldSkill check dist:", dist, "validDist:", validDist)
                        end
                        if dist <= validDist then
                            shouldBlock = true
                            lastAttackLength = track.Length
                            AutoBlock._lastAnimId = flag.animId
                            attackerHRP = hrp
                            return
                        end
                    else
                        local length = track.Length
                        local timePos = track.TimePosition
                        local isRanged = longBlockAnimations[flag.animId]
                        local holdUntil = (length > 0.1) and (length * 0.6) or (isRanged and 0.8 or 0.35)
                        if not isRanged and holdUntil > 0.45 then holdUntil = 0.45 end
                        local currentPos = (length > 0.1) and timePos or elapsed

                        if AutoBlock.Debug2 then
                            local validDist2 = (isRanged and 45 or AutoBlock.TriggerDistance) + velBonus
                            print(string.format("[AB Debug2] %s anim:%s len:%.2f cur:%.2f hold:%.2f dist:%.1f maxDist:%.1f noBlock:%s",
                                char.Name,
                                tostring(flag.animId):sub(-8),
                                length, currentPos, holdUntil, dist, validDist2,
                                tostring(noBlockAnimations[flag.animId])))
                        end

                        if currentPos <= holdUntil then
                            local validDist = (isRanged and 45 or AutoBlock.TriggerDistance) + velBonus
                            if dist <= validDist and not noBlockAnimations[flag.animId] then
                                shouldBlock = true
                                lastAttackLength = length
                                AutoBlock._lastAnimId = flag.animId
                                attackerHRP = hrp
                                if directionalAnimations[flag.animId] and AutoBlock.AntiSpin then
                                    spinTargetPos = hrp.Position
                                end
                                return
                            end
                        else
                            _abInstant.flags[char] = nil
                        end
                    end
                else
                    _abInstant.flags[char] = nil
                end
            end

            -- Polling fallback: scan playing animation tracks
            local hum = char:FindFirstChildOfClass("Humanoid")
            local animator = hum and hum:FindFirstChildOfClass("Animator")
            if not animator then return end

            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                local animId = track.Animation and track.Animation.AnimationId
                if animId and attackAnimations[animId] then
                    if noBlockAnimations[animId] then continue end

                    local isRanged = longBlockAnimations[animId]
                    local validDist = (isRanged and 45 or AutoBlock.TriggerDistance) + velBonus

                    if dist <= validDist then
                        local timePos = track.TimePosition
                        local length = track.Length
                        local adjustedPos = math.max(timePos - recvPing, 0)
                        
                        -- HoldBlockSkill in polling: keep blocking while playing
                        local animNumId = tostring(animId):match("%d+")
                        local isHoldSkill = animNumId and holdBlockAnimIds["rbxassetid://" .. animNumId]
                        
                        if isHoldSkill then
                            if track.IsPlaying then
                                shouldBlock = true
                                lastAttackLength = length
                                AutoBlock._lastAnimId = animId
                                attackerHRP = hrp
                                break
                            end
                        else
                            local holdUntil = length * 0.6
                            if not isRanged and holdUntil > 0.45 then
                                holdUntil = 0.45
                            end

                            if length == 0 or adjustedPos <= holdUntil then
                                shouldBlock = true
                                lastAttackLength = length
                                AutoBlock._lastAnimId = animId
                                attackerHRP = hrp
                                if directionalAnimations[animId] and AutoBlock.AntiSpin then
                                    spinTargetPos = hrp.Position
                                end
                                break
                            end
                        end
                    end
                end
            end
        end

        -- Scan all players
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                scanCharacter(player.Character)
            end
            if shouldBlock then break end
        end

        -- Scan workspace.Characters (NPCs, summons, clones)
        if not shouldBlock then
            local charsFolder = workspace:FindFirstChild("Characters")
            if charsFolder then
                for _, c in ipairs(charsFolder:GetChildren()) do
                    scanCharacter(c)
                    if shouldBlock then break end
                end
            end
        end

        -- Scan Dummies / TrainingDummies
        if not shouldBlock then
            local dummiesFolder = workspace:FindFirstChild("Dummies") or workspace:FindFirstChild("TrainingDummies")
            if dummiesFolder then
                for _, c in ipairs(dummiesFolder:GetChildren()) do
                    scanCharacter(c)
                    if shouldBlock then break end
                end
            end
        end

        -- [Divine Dog / Totality] Frame-by-frame Scan (User logic integration)
        if not shouldBlock then
            local effects = workspace:FindFirstChild("Effects")
            if effects then
                for _, dog in ipairs(effects:GetChildren()) do
                    if dog.Name == "Totality" then
                        local root = dog:FindFirstChild("RootPart") or dog.PrimaryPart
                        local target = dog:FindFirstChild("Target")
                        if root and target and target:IsA("ObjectValue") and target.Value == lpChar then
                            local dist = (root.Position - lpHrp.Position).Magnitude
                            if dist <= 12 then
                                shouldBlock = true
                                attackerHRP = root
                                break
                            end
                        end
                    end
                end
            end
        end

        if shouldBlock then
            AutoBlock.LastActiveAttack = tick()
            _abInstant.lastHRP = attackerHRP
        end
        
        local graceExt = 0.05
        if AutoBlock._lastAnimId then
            if longBlockAnimations[AutoBlock._lastAnimId] then
                graceExt = 0.35
            end
            local numMatch = tostring(AutoBlock._lastAnimId):match("%d+")
            if holdBlockAnimIds[AutoBlock._lastAnimId] or (numMatch and holdBlockAnimIds["rbxassetid://"..numMatch]) then
                graceExt = AutoBlock.SkillGracePeriod or 0.5
            end
        end
        
        local isComboGracePeriod = false
        if AutoBlock.LastActiveAttack and (tick() - AutoBlock.LastActiveAttack < graceExt) then
            isComboGracePeriod = true
        end
        
        local shouldBlockFinal = shouldBlock or isComboGracePeriod or (AutoBlock._projForceBlock == true)
        if shouldBlockFinal and not AutoBlock.CurrentlyBlocking then
            AutoBlock.CurrentlyBlocking = true
            simulateBlockDown()
        elseif not shouldBlockFinal and AutoBlock.CurrentlyBlocking then
            AutoBlock.CurrentlyBlocking = false
            simulateBlockUp()
        end

        -- Anti-Spin: face strictly TOWARDS spin attacker
        if AutoBlock.AntiSpin and shouldBlock and spinTargetPos then
            pcall(function()
                local char_ = LocalPlayer.Character
                local hrp_ = char_ and (char_:FindFirstChild("HumanoidRootPart") or char_.PrimaryPart)
                local hum_ = char_ and char_:FindFirstChildOfClass("Humanoid")
                if hrp_ and hum_ then
                    -- Dynamic Frame-by-Frame Tracking: don't look at the snapshot, look at their live position!
                    local liveTargetPos = attackerHRP and attackerHRP.Position or spinTargetPos
                    local targetPos = Vector3.new(liveTargetPos.X, hrp_.Position.Y, liveTargetPos.Z)
                    
                    -- Predictive Tracking: Counter attacker-sided hit reg by turning to where they WILL be
                    if attackerHRP then
                        local vel = attackerHRP.AssemblyLinearVelocity
                        if vel and vel.Magnitude > 15 then
                            -- Extrapolate future position based on our ping delay (capped slightly so we don't wildly overflick)
                            local pingTicks = math.clamp(recvPing or 0.1, 0.05, 0.25)
                            targetPos = targetPos + Vector3.new(vel.X, 0, vel.Z) * pingTicks
                        end
                    end
                    
                    -- Prevent snapping errors if distance is essentially 0
                    if (targetPos - hrp_.Position).Magnitude > 0.1 then
                        hum_.AutoRotate = false -- Strip control from Roblox engine locally
                        hrp_.CFrame = CFrame.lookAt(hrp_.Position, targetPos)
                    end
                end
            end)
        else
            -- Restore native controls when not actively tracking
            pcall(function()
                local char_ = LocalPlayer.Character
                local hum_ = char_ and char_:FindFirstChildOfClass("Humanoid")
                if hum_ and not hum_.AutoRotate then
                    hum_.AutoRotate = true
                end
            end)
        end
    end)
    table.insert(ab_conns, rs_conn)

    game:GetService("UserInputService").InputBegan:Connect(function(input, gpe)
        if gpe then return end
        local keys = {Enum.KeyCode.One, Enum.KeyCode.Two, Enum.KeyCode.Three, Enum.KeyCode.Four}
        if table.find(keys, input.KeyCode) then
            local char = LocalPlayer.Character
            if char and (tostring(char:GetAttribute("Moveset")):find("Megumi") or tostring(char:GetAttribute("Character")):find("Megumi")) then
                AutoBlock._megumiImmunity = tick()
            end
        end
    end)
end

