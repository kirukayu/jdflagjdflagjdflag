local active_tweens = {
	Color = {},
	Color3 = {},
	Size = {},
	tween_position = {},
	Position = {},
	tween_size = {},
	Transparency = {},
	FillTransparency = {},
	OutlineTransparency = {},
	BackgroundTransparency = {},
