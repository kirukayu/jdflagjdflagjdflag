local bl_section = group:create_section("Blacklist", "Blacklisted Moves", 1, 0.50, 0)

local function rebuildNoBlock()
    table.clear(noBlockAnimations)
    local animsObj = game:GetService("ReplicatedStorage"):FindFirstChild("Animations")
    if not animsObj then return end
    local skipFolders = {["Misc"] = true, ["Movement"] = true, ["Idle"] = true}
    local blacklist = {"idle", "sacrileg"}
    for _, charFolder in ipairs(animsObj:GetChildren()) do
        if skipFolders[charFolder.Name] then continue end
        for _, obj in ipairs(charFolder:GetDescendants()) do
            if obj:IsA("Animation") then
                local skip = false
                local name = obj.Name:lower()
                for _, word in ipairs(blacklist) do
                    if string.find(name, word) then
                        skip = true
                        break
                    end
                end
                
                local parent = obj.Parent
                while parent and parent ~= charFolder do
                    if skipFolders[parent.Name] then skip = true break end
                    parent = parent.Parent
                end
                if not skip then
                    local cLower = charFolder.Name:lower()
                    local mLower = obj.Name:lower()
                    
                    if string.find(mLower, "chase") and AutoBlock.MoveBlacklist["All/Chase"] then
                        noBlockAnimations[obj.AnimationId] = true
                    end

                    if string.find(cLower, "charles") then
                        if string.find(mLower, "despair") and AutoBlock.MoveBlacklist["Charles/Despair"] then
                            noBlockAnimations[obj.AnimationId] = true
                        elseif string.find(mLower, "shutup") then
                            if string.find(mLower, "victim") and AutoBlock.MoveBlacklist["Charles/ShutUpVictim"] then
                                noBlockAnimations[obj.AnimationId] = true
                            elseif not string.find(mLower, "victim") and AutoBlock.MoveBlacklist["Charles/ShutUp"] then
                                noBlockAnimations[obj.AnimationId] = true
                            end
                        end
                    elseif string.find(cLower, "hakari") then
                        if string.find(mLower, "rough") and AutoBlock.MoveBlacklist["Hakari/RoughEnergy"] then
                            noBlockAnimations[obj.AnimationId] = true
                        end
                    elseif string.find(cLower, "higuruma") or string.find(cLower, "hiromi") then
                        if string.find(mLower, "judge") and AutoBlock.MoveBlacklist["Higuruma/JudgeReach"] then
                            noBlockAnimations[obj.AnimationId] = true
                        end
                    elseif string.find(cLower, "meimei") then
                        if mLower == "melee4" then
                            noBlockAnimations[obj.AnimationId] = true
                        end
                    elseif string.find(cLower, "hanami") then
                        if mLower == "arm" or mLower == "defenseresponse" or mLower == "rootswarm" then
                            noBlockAnimations[obj.AnimationId] = true
                        end
                    end
                end
            end
        end
    end
end

