-- ============================================================
-- Hold Block For Skills (STANDALONE - completely independent)
-- When enemy uses a skill from HoldBlockSkills, this system:
-- 1. Forces block ON
-- 2. Holds block while enemy's skill animation is playing
-- 3. When skill animation stops -> release block -> M1 punch
-- ============================================================
do
    local _hbs_hooked = {}
    AutoBlock._hbs_active = false
    
    local function hookEnemyForHoldBlock(char)
        if _hbs_hooked[char] then return end
        _hbs_hooked[char] = true
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        local animator = hum and (hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 3))
        if not animator then _hbs_hooked[char] = nil return end
        
        local conn = animator.AnimationPlayed:Connect(function(track)
            if AutoBlock._hbs_active then return end
            if not AutoBlock.Enabled then return end
            
            local animId = track.Animation and track.Animation.AnimationId
            if not animId then return end
            
            local isHoldMatch = false
            local numId = tostring(animId):match("%d+")
            
            -- User's idea: Literally just check if the animation's NAME contains "despair"
            pcall(function()
                local tName = track.Name and string.lower(track.Name) or ""
                local aName = track.Animation and track.Animation.Name and string.lower(track.Animation.Name) or ""
                if string.find(tName, "despair") or string.find(aName, "despair") then
                    isHoldMatch = true
                end
            end)
            
            -- Fallback to the loaded map for other skills
            if not isHoldMatch then
                local numId = tostring(animId):match("%d+")
                if numId and holdBlockAnimIds["rbxassetid://" .. numId] then
                    isHoldMatch = true
                end
            end
            
            if not isHoldMatch then return end
            
            -- Check distance
            local lpChar = LocalPlayer.Character
            local lpHrp = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
            local eHrp = char:FindFirstChild("HumanoidRootPart")
            if not lpHrp or not eHrp then return end
            if (eHrp.Position - lpHrp.Position).Magnitude > 30 then return end
            
            -- ENEMY IS USING A HOLD-BLOCK SKILL NEAR US
            AutoBlock._hbs_active = true
            
            task.spawn(function()
                -- Force block ON
                simulateBlockDown()
                AutoBlock.CurrentlyBlocking = true
                AutoBlock.LastActiveAttack = tick()
                
                -- Hold block while skill animation is playing (or during combo gaps)
                local startTime = tick()
                local lastSeenPlaying = tick()
                while (tick() - startTime) < 8.0 do
                    if not AutoBlock._hbs_active then break end
                    local isComboPlaying = false
                    
                    pcall(function()
                        for _, pTrack in ipairs(animator:GetPlayingAnimationTracks()) do
                            if pTrack.IsPlaying then
                                local id = pTrack.Animation and pTrack.Animation.AnimationId
                                local matchId = id and tostring(id):match("%d+")
                                
                                if holdBlockAnimIds[id] or (matchId and holdBlockAnimIds["rbxassetid://"..matchId]) then
                                    isComboPlaying = true
                                    break
                                end
                                
                                pcall(function()
                                    local tName = pTrack.Name and string.lower(pTrack.Name) or ""
                                    local aName = pTrack.Animation and pTrack.Animation.Name and string.lower(pTrack.Animation.Name) or ""
                                    if string.find(tName, "despair") or string.find(aName, "despair") then
                                        isComboPlaying = true
                                    end
                                end)
                                
                                if isComboPlaying then break end
                            end
                        end
                    end)
                    
                    if isComboPlaying then
                        lastSeenPlaying = tick()
                    end
                    
                    -- If animation drops, wait up to SkillGracePeriod before releasing
                    if (tick() - lastSeenPlaying) > (AutoBlock.SkillGracePeriod or 0.5) then
                        break
                    end
                    
                    -- Keep forcing block every frame (override any release attempts)
                    AutoBlock.CurrentlyBlocking = true
                    AutoBlock.LastActiveAttack = tick()
                    simulateBlockDown()
                    
                    task.wait()
                end
                
                if not AutoBlock._hbs_active then 
                    simulateBlockUp()
                    AutoBlock.CurrentlyBlocking = false
                    return 
                end -- DIE SILENTLY IF ABORTED!
                
                -- Skill ended -> release block -> M1
                task.wait() -- 1 frame buffer
                
                simulateBlockUp()
                AutoBlock.CurrentlyBlocking = false
                AutoBlock.LastActiveAttack = 0
                AutoBlock._punchCooldown = tick()
                
                -- M1 removed from here: native AutoPunch handles the punish now
                -- (User reverted to native AutoPunch priority to avoid double hits)
                
                AutoBlock._hbs_active = false
            end)
        end)
        table.insert(ab_conns, conn)
        
        char.AncestryChanged:Connect(function(_, parent)
            if not parent then _hbs_hooked[char] = nil end
        end)
    end
    
    -- Hook all current + future players
    local function hookAllForHoldBlock()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                hookEnemyForHoldBlock(plr.Character)
            end
        end
    end
    
    hookAllForHoldBlock()
    Players.PlayerAdded:Connect(function(plr)
        plr.CharacterAdded:Connect(function(char)
            task.wait(0.5)
            hookEnemyForHoldBlock(char)
        end)
    end)
    for _, plr in ipairs(Players:GetPlayers()) do
        plr.CharacterAdded:Connect(function(char)
            task.wait(0.5)
            hookEnemyForHoldBlock(char)
        end)
    end
    
    -- Also scan periodically for missed characters
    task.spawn(function()
        while task.wait(3) do
            hookAllForHoldBlock()
        end
    end)
