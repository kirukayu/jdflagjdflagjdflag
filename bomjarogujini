do
local esp_library = {
    settings = {
        master_switch = true;
        max_distance = 2000;
        boxes = {
            enabled = true;
            color  = Color3.fromRGB(235, 235, 235);
            gradient = {true, Color3.fromRGB(235, 235, 235), Color3.fromRGB(150, 150, 150)};
