-- ============================================================
-- BF Chain: auto side-dash behind target + BF
-- Mode: "Legit" = side-dash approach, "Blatant" = CFrame teleport
-- ============================================================

local function getDotFront(targetHRP, myRoot)
    if not targetHRP or not myRoot then return 1 end
    local look = targetHRP.CFrame.LookVector
    local toMe = myRoot.Position - targetHRP.Position
    local hLook = Vector3.new(look.X, 0, look.Z)
    local hToMe = Vector3.new(toMe.X, 0, toMe.Z)
    if hLook.Magnitude < 0.001 or hToMe.Magnitude < 0.001 then return 1 end
    return hLook.Unit:Dot(hToMe.Unit)
end

local function isBehindStrict(targetHRP, myRoot)
    return getDotFront(targetHRP, myRoot) <= -0.5
end

local function executeBlatantChain(targetHRP, nearestTarget)
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart") or myChar.PrimaryPart
    if not myRoot or not targetHRP or not targetHRP.Parent then return end

    local look = targetHRP.CFrame.LookVector
    local hLook = Vector3.new(look.X, 0, look.Z)
    if hLook.Magnitude < 0.001 then return end
    hLook = hLook.Unit

    local behindPos = targetHRP.Position - hLook * 4
    behindPos = Vector3.new(behindPos.X, myRoot.Position.Y, behindPos.Z)
    local lookAtEnemy = targetHRP.Position
    lookAtEnemy = Vector3.new(lookAtEnemy.X, myRoot.Position.Y, lookAtEnemy.Z)

    myRoot.CFrame = CFrame.lookAt(behindPos, lookAtEnemy)
end

local function executeLegitChain(targetHRP, nearestTarget)
    local maxSteps = 40
    local step = 0
    local curRoot = LocalPlayer.Character and (LocalPlayer.Character:FindFirstChild("HumanoidRootPart") or LocalPlayer.Character.PrimaryPart)
    if not curRoot or not targetHRP or not targetHRP.Parent then return end

    local dotCache = getDotFront(targetHRP, curRoot)
    if dotCache <= -0.5 then
        return 
    end

    local enemyLook = targetHRP.CFrame.LookVector
    local hEnemyLook = Vector3.new(enemyLook.X, 0, enemyLook.Z)
    if hEnemyLook.Magnitude < 0.001 then return end
    hEnemyLook = hEnemyLook.Unit

    local behindPos = targetHRP.Position - hEnemyLook * 4
    local toIdeal = behindPos - curRoot.Position
    local hToIdeal = Vector3.new(toIdeal.X, 0, toIdeal.Z)
    if hToIdeal.Magnitude < 0.3 then return end
    hToIdeal = hToIdeal.Unit

    local camRight = Camera.CFrame.RightVector
    local hCamRight = Vector3.new(camRight.X, 0, camRight.Z)
    if hCamRight.Magnitude < 0.001 then hCamRight = Vector3.new(1, 0, 0) end
    hCamRight = hCamRight.Unit

    local goL = hToIdeal:Dot(hCamRight) < 0

    -- Start the dash
    sideDash(goL)

    -- A typical side dash in JS takes ~0.25 - 0.3s. 
    -- The arc naturally curves due to the TempLock RenderStepped tracking.
    -- Waiting exactly 0.17 seconds places them perfectly behind the enemy without overshooting!
    task.wait(0.17)

    -- "Normally" stop the dash! Tapping a walk key forces the engine to cancel the dash momentum native!
    sideWalk(goL, 0.06)
end

