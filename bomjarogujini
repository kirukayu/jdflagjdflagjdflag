-- Build hold-block-skill anim IDs from RS.Animations
local holdBlockAnimIds = {}
local holdBlockAnimGraces = {}
local function buildHoldBlockAnims()
    table.clear(holdBlockAnimIds)
    table.clear(holdBlockAnimGraces)
    local animsRoot = game:GetService("ReplicatedStorage"):FindFirstChild("Animations")
    if not animsRoot then return end
    for skillName, graceTime in pairs(AutoBlock.HoldBlockSkills) do
        local lowerSkill = string.lower(skillName)
        for _, charFolder in ipairs(animsRoot:GetChildren()) do
            for _, obj in ipairs(charFolder:GetDescendants()) do
                if obj:IsA("Animation") and obj.AnimationId ~= "" then
                    local pName = obj.Parent and string.lower(obj.Parent.Name) or ""
                    local oName = string.lower(obj.Name)
                    -- Match if the Animation ITSELF is named like the skill, OR its parent folder is named like the skill
                    if oName == lowerSkill or pName == lowerSkill then
                        holdBlockAnimIds[obj.AnimationId] = true
                        holdBlockAnimGraces[obj.AnimationId] = graceTime
                        local numId = obj.AnimationId:match("%d+")
                        if numId then
                            holdBlockAnimIds["rbxassetid://" .. numId] = true
                            holdBlockAnimGraces["rbxassetid://" .. numId] = graceTime
                            if AutoBlock.Debug then
                                print("[AutoBlock] Mapped HoldSkill:", skillName, "->", numId, "Path:", obj:GetFullName())
                            end
                        end
                    end
                end
            end
        end
    end
end

