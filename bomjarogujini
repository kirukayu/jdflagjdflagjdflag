task.spawn(function()
    if game:GetService("Lighting"):FindFirstChild("OBLV_SoundTracker_Daemon") then return end
    local marker = Instance.new("Folder")
    marker.Name = "OBLV_SoundTracker_Daemon"
    marker.Parent = game:GetService("Lighting")

    local localPlayer = game:GetService("Players").LocalPlayer
    local uis = game:GetService("UserInputService")
    
    -- Лимит 5 секунд для Фредди
    local localLastSlam = 0
    
    -- Отслеживаем нажатие кнопки 2, и сбрасываем если нажат другой скилл!
    local lastTwoPress = 0
    uis.InputBegan:Connect(function(input, gameProcessed)
        if input.KeyCode == Enum.KeyCode.Two then
            lastTwoPress = os.clock()
        elseif input.KeyCode == Enum.KeyCode.One or 
               input.KeyCode == Enum.KeyCode.Three or 
               input.KeyCode == Enum.KeyCode.Four or 
               input.KeyCode == Enum.KeyCode.R then
            -- Если после двойки сразу нажал 4 (или другой скилл), отменяем ожидание Фредди!
            lastTwoPress = 0
        end
    end)
    
    local function checkAndPlay(sound)
        local now = os.clock()
        
        -- САМОЕ ГЛАВНОЕ: Проверяем, была ли нажата двойка в последние 1.5 секунды
        -- Окно сужено с 3 до 1.5 сек, так как скилл кастуется быстро.
        if now - lastTwoPress > 1.5 then return end
        
        local lastPlay = marker:GetAttribute("LastPlay") or 0
        -- ЖЕСТКИЙ ЛИМИТ В 5 СЕКУНД
        if (now - localLastSlam) < 5 then return end
        if (now - lastPlay) < 5 then return end
        
        -- Проверка радиуса: источник звука (Part) должен быть <= 10 стадов от нас
        if sound.Parent and sound.Parent:IsA("BasePart") then
            local lpChar = localPlayer.Character
            if lpChar and lpChar:FindFirstChild("HumanoidRootPart") then
                local dist = (lpChar.HumanoidRootPart.Position - sound.Parent.Position).Magnitude
                if dist <= 10 then
                    localLastSlam = now
                    marker:SetAttribute("LastPlay", now)
                    if getgenv().OBLV_Audio then
                        -- Врубаем Фредди!
                        getgenv().OBLV_Audio.Play("freddy-backshots", 2.0)
                    end
                end
            end
        end
    end

    local function hookSound(desc)
        if desc:IsA("Sound") then
            local isValid = false
            pcall(function()
                local rs = game:GetService("ReplicatedStorage")
                local template = rs:FindFirstChild("Sounds") and rs.Sounds:FindFirstChild("Hakari") 
                    and rs.Sounds.Hakari:FindFirstChild("ShutterDoors") and rs.Sounds.Hakari.ShutterDoors:FindFirstChild("Slam")
                
                if template and desc.SoundId == template.SoundId then
                    isValid = true
                elseif desc.Name == "Slam" then
                    isValid = true
                end
            end)

            if isValid then
                desc.Played:Connect(function()
                    checkAndPlay(desc)
                end)
            end
        end
    end

    game.Workspace.DescendantAdded:Connect(hookSound)
    
    for _, desc in ipairs(game.Workspace:GetDescendants()) do
        hookSound(desc)
    end
end)
