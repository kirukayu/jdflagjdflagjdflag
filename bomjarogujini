-- ============================================================
-- Lock On: camera lock to nearest enemy
-- ============================================================

RunService.RenderStepped:Connect(function()
    if not LockOn.Active or not LockOn.Target then return end

    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart") or myChar.PrimaryPart
    if not myRoot then return end

    local targetChar = LockOn.Target
    local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart") or targetChar.PrimaryPart

    if not targetHum or targetHum.Health <= 0 or not targetHRP then
        LockOn.Active = false
        LockOn.Target = nil
        return
    end

    local dist = (myRoot.Position - targetHRP.Position).Magnitude
    if dist > LockOn.MaxDist then
        LockOn.Active = false
        LockOn.Target = nil
        return
    end

    local aimPart = targetChar:FindFirstChild(LockOn.AimPart)
        or targetChar:FindFirstChild("UpperTorso")
        or targetHRP
    local aimPoint = aimPart.Position

    local camPos = Camera.CFrame.Position
    local lookAtCF = CFrame.lookAt(camPos, aimPoint)
    local sm = LockOn.Smoothness or 30
    if sm <= 0 then
        Camera.CFrame = lookAtCF
    else
        Camera.CFrame = Camera.CFrame:Lerp(lookAtCF, 1 / sm)
    end
end)


