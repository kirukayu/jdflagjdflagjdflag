-- Lock On helpers
-- ============================================================

local function getLockOnTarget()
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart") or myChar.PrimaryPart
    if not myRoot then return nil end

    local best, bestDist = nil, LockOn.MaxDist

    local function check(char)
        if not char or char == myChar then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        local hrp = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
        if not hrp then return end
        local d = (myRoot.Position - hrp.Position).Magnitude
        if d < bestDist then
            bestDist = d
            best = char
        end
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then check(plr.Character) end
    end

    local cf = workspace:FindFirstChild("Characters")
    if cf then for _, c in ipairs(cf:GetChildren()) do check(c) end end

    local df = workspace:FindFirstChild("Dummies") or workspace:FindFirstChild("TrainingDummies")
    if df then for _, c in ipairs(df:GetChildren()) do check(c) end end

    return best
end

