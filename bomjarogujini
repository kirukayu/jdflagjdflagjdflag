		function(label, limit, callback, numbers, allow_enter, allow_all, only_on_enter) -- > LOL dont ask im too lazy to rewrite this >->
			if active_typing then
				stop_typing()
				return
			end

			type_line["Size"] = udim2_new(0, 1, 0, label["Size"] - 1)
			active_typing = label
