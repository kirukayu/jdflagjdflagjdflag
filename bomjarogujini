            distance = true;
            font = "Roboto";
            color = Color3.fromRGB(235, 235, 235);
        };
    };
};

local _tick = tick();
local rotation_angle = 90;

local esp_funcs = {}; do
    function esp_funcs:create(class, properties)
        local instance = Instance.new(class);
        for property, value in properties do
            instance[property] = value;
        end;
        return instance;
    end;

    function esp_funcs:vector_2_floor(position)
        return Vector2.new(math.floor(position.X), math.floor(position.Y))
    end

    function esp_funcs:cframe_to_viewport(cframe, floor)
        local position, visible = Camera:WorldToViewportPoint(cframe * (cframe - cframe.p):ToObjectSpace(Camera.CFrame - Camera.CFrame.p).p)
        if floor then
            position = esp_funcs:vector_2_floor(position)
        end
        return position, visible
    end    

    function esp_funcs:get_box_size(position, cframe)
        if esp_library.settings.boxes.bounding then
            local size = Vector3.new(4, 5.75, 1.5)
            local x = esp_funcs:cframe_to_viewport(cframe * CFrame.new(size.X, 0, 0))
            local y = esp_funcs:cframe_to_viewport(cframe * CFrame.new(0, size.Y, 0))
            local z = esp_funcs:cframe_to_viewport(cframe * CFrame.new(0, 0, size.Z))
            local SizeX = math.max(math.abs(position.X - x.X), math.abs(position.X - z.X))
            local SizeY = math.max(math.abs(position.Y - y.Y), math.abs(position.Y - x.Y))
            return Vector2.new(math.clamp(math.floor(SizeX), 3, math.huge), math.clamp(math.floor(SizeY), 6, math.huge))
        else
            local distance = (Camera.CFrame.p - cframe.p).magnitude
            local factor = 1 / ((distance / 3) * math.tan(math.rad(Camera.FieldOfView / 2)) * 2) * 1000
            return Vector2.new(math.clamp(math.floor(factor * 1.3), 3, math.huge), math.clamp(math.floor(factor * 2.1), 6, math.huge))
        end
    end
end;

local function setup_esp()
    local text_font = Enum.Font.Roboto -- Roboto is guaranteed to exist
    pcall(function()
        if not isfile("proggyclean.ttf") then
            writefile("proggyclean.ttf", game:HttpGet("https://raw.githubusercontent.com/f1nobe7650/other/main/ProggyClean.ttf"));
        end
        local getsynasset = getcustomasset or getsynasset
        if getsynasset then
            local FontMod = setreadonly(Font, false);
            if not isfile("proggyclean.font") then
                local Data = {
                    name = "proggyclean",
                    faces = {{
                        name = "Regular",
                        weight = 400,
                        style = "normal",
                        assetId = getsynasset("proggyclean.ttf");
                    }}
                };
                writefile("proggyclean.font", game:GetService("HttpService"):JSONEncode(Data));
            end
            proggy_font = Font.new(getsynasset("proggyclean.font"));
        end
    end)
    
    local function get_font(font_name)
        if font_name == "ProggyClean" and proggy_font then
            return proggy_font
        end
        -- Default to Roboto if name is invalid or Enum member doesn't exist
        local success, font_enum = pcall(function() return Enum.Font[font_name] end)
        return success and Font.fromEnum(font_enum) or Font.fromEnum(Enum.Font.Roboto)
    end

    local screen_gui = esp_funcs:create("ScreenGui", {
        Parent = cloneref(game:GetService("CoreGui")),
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        Name = "OBLV_ESP"
    })

    local remove_esp = function(player)
        if screen_gui:FindFirstChild(player.Name) then
            screen_gui[player.Name]:Destroy();
        end;
    end;

    local create_esp = function(player)
        if player == LocalPlayer then return end
        local player_folder = esp_funcs:create("Folder", {Parent = screen_gui, Name = player.Name})
        local box_main = esp_funcs:create("Frame", {Visible = false; Parent = player_folder, BackgroundColor3 = Color3.fromRGB(0, 0, 0), BackgroundTransparency = 1, BorderSizePixel = 0});
        local box_outline = esp_funcs:create("UIStroke", {Parent = box_main, Enabled = false, Transparency = 0, Color = Color3.fromRGB(255, 255, 255)});
        local box_gradient = esp_funcs:create("UIGradient", {Rotation = 90,Parent = box_main, Enabled = false})
        local box_outline_gradient = esp_funcs:create("UIGradient", {Rotation = 90,Parent = box_outline, Enabled = false})
        local nametag = esp_funcs:create("TextLabel", {Name = "nametag", BackgroundTransparency = 1, RichText = true, TextXAlignment = Enum.TextXAlignment.Center; BorderSizePixel = 0, Visible = false, Parent = player_folder, TextSize = 12, FontFace = final_font, TextStrokeTransparency = 0, TextColor3 = Color3.fromRGB(255,255,255), AutomaticSize = Enum.AutomaticSize.X});
        local behind_healthbar = esp_funcs:create("Frame", {BackgroundTransparency = 1, BorderSizePixel = 0, Parent = player_folder, Visible = false});
        local health_bar_outline = esp_funcs:create("UIStroke", {Parent = behind_healthbar,Transparency = 0, Color = Color3.fromRGB(0, 0, 0)});
        local inside_healthbar = esp_funcs:create("Frame", {Parent = behind_healthbar, AnchorPoint = Vector2.new(0,1), Position = UDim2.new(0,0,1,0), Size = UDim2.new(1,0,0,0)})
        local health_bar_gradient = esp_funcs:create("UIGradient", {Rotation = 90,Parent = inside_healthbar, Enabled = false})
        local health_bar_text = esp_funcs:create("TextLabel", {Name = "healthtext", BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Center; BorderSizePixel = 0, Visible = false, Parent = inside_healthbar, TextSize = 12, FontFace = final_font, TextStrokeTransparency = 0, TextColor3 = Color3.fromRGB(255,255,255), AutomaticSize = Enum.AutomaticSize.X});

        local update_esp = function()
            local esp_connection;
            local hide_esp = function()
                box_main.Visible  = false;
                nametag.Visible = false;
                behind_healthbar.Visible = false;
            end;

            esp_connection = RunService.RenderStepped:Connect(function()
                if not player.Parent then
                    player_folder:Destroy();
                    esp_connection:Disconnect();
                    return
                end

                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local humanoid = char and char:FindFirstChild("Humanoid")

                if hrp and humanoid then
                    local screen_position, visible = Camera:WorldToViewportPoint(hrp.Position);
                    local distance = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude) or 0
                    
                    if visible and distance <= esp_library.settings.max_distance then
                        if esp_library.settings.master_switch then
                            local box_size = esp_funcs:get_box_size(Vector2.new(screen_position.X, screen_position.Y), hrp.CFrame * CFrame.new(0,.25,0));
                            local box_position = esp_funcs:vector_2_floor(Vector2.new(screen_position.X, screen_position.Y + 5) - box_size / 2);

                            -- Boxes
                            box_main.Visible = esp_library.settings.boxes.enabled;
                            box_gradient.Enabled = esp_library.settings.boxes.gradient[1] 
                            box_gradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, esp_library.settings.boxes.gradient[2]), ColorSequenceKeypoint.new(1, esp_library.settings.boxes.gradient[3])}
                            box_outline_gradient.Enabled = esp_library.settings.boxes.gradient[1] 
                            box_outline_gradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, esp_library.settings.boxes.gradient[2]), ColorSequenceKeypoint.new(1, esp_library.settings.boxes.gradient[3])}
                            box_outline.Enabled = esp_library.settings.boxes.enabled;
                            box_outline.Color = esp_library.settings.boxes.color
                            box_main.Position = UDim2.new(0, box_position.X, 0, box_position.Y)
                            box_main.Size = UDim2.new(0, box_size.X, 0, box_size.Y);

                            if esp_library.settings.boxes.filled.enabled then
                                box_main.BackgroundTransparency = esp_library.settings.boxes.filled.transparency;
                                box_main.BackgroundColor3 = esp_library.settings.boxes.filled.color;
                            else
                                box_main.BackgroundTransparency = 1
                            end

                            if esp_library.settings.boxes.animate then
                                rotation_angle = rotation_angle + (tick() - _tick) * esp_library.settings.boxes.animatespeed * math.cos(math.pi / 4 * tick() - math.pi / 2)
                                box_gradient.Rotation = rotation_angle;
                                box_outline_gradient.Rotation = rotation_angle;
                            else
                                box_gradient.Rotation = 90;
                                box_outline_gradient.Rotation = 90;
                            end
                            _tick = tick();

                            -- Names & Flags
                            nametag.Visible = esp_library.settings.names.enabled;
                            nametag.TextColor3 = esp_library.settings.names.color;
                            nametag.TextStrokeTransparency = esp_library.settings.names.outline and 0 or 1;
                            nametag.FontFace = get_font(esp_library.settings.names.font)

                            local name_text = esp_library.settings.names.type == "lower" and string.lower(player.DisplayName) or string.upper(player.DisplayName)
                            if esp_library.settings.flags.distance[1] then
                                name_text = string.format('%s (<font color="rgb(150, 150, 150)">%d</font>)', name_text, math.floor(distance))
                            end
                            nametag.Text = name_text;
                            nametag.Size = UDim2.new(0, box_size.X, 0, 0)
                            nametag.Position = UDim2.new(0, box_position.X, 0, box_position.Y - 10);
                            nametag.TextXAlignment = Enum.TextXAlignment[esp_library.settings.names.layout];

                            -- Healthbars
                            behind_healthbar.Visible = esp_library.settings.health_bars.enabled;
                            behind_healthbar.Size = UDim2.new(0, esp_library.settings.health_bars.thickness, 0, box_size.Y);
                            behind_healthbar.Position = UDim2.new(0, box_position.X - esp_library.settings.health_bars.offset, 0, box_position.Y);
                            inside_healthbar.BackgroundColor3 = esp_library.settings.health_bars.color;
                            health_bar_gradient.Enabled = esp_library.settings.health_bars.gradient[1];
                            health_bar_gradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, esp_library.settings.health_bars.gradient[2]), ColorSequenceKeypoint.new(1, esp_library.settings.health_bars.gradient[3])}
                            health_bar_text.Visible = esp_library.settings.health_bars.text;
                            health_bar_text.TextColor3 = esp_library.settings.health_bars.color;
                            health_bar_text.FontFace = get_font(esp_library.settings.health_bars.font)

                            local health = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1);
                            inside_healthbar.Size = UDim2.fromScale(1, health);
                            health_bar_text.Text = tostring(math.floor(health * 100 + 0.5));
                            if esp_library.settings.health_bars.use_health_color then
                                inside_healthbar.BackgroundColor3 = Color3.fromHSV(health * 0.3, 1, 1);
                                health_bar_gradient.Enabled = false;
                            end
                        else
                            hide_esp();
                        end
                    else
                        hide_esp();
                    end
                else
                    hide_esp();
                end
            end);
        end;
        coroutine.wrap(update_esp)()
    end;

    for _, v in ipairs(Players:GetPlayers()) do
        create_esp(v)
    end
    Players.PlayerAdded:Connect(create_esp)
    Players.PlayerRemoving:Connect(remove_esp)

    -- Item ESP Logic
    local function create_item_esp(item)
        if not item:IsA("Model") and not item:IsA("BasePart") then return end
        
        local item_folder = esp_funcs:create("Folder", {Parent = screen_gui, Name = "Item_" .. item.Name .. "_" .. tostring(math.random(1000, 9999))})
        local label = esp_funcs:create("TextLabel", {
            Name = "itemlabel",
            BackgroundTransparency = 1,
            RichText = true,
            TextXAlignment = Enum.TextXAlignment.Center,
            BorderSizePixel = 0,
            Visible = false,
            Parent = item_folder,
            TextSize = 13,
            TextStrokeTransparency = 0,
            TextColor3 = esp_library.settings.item_esp.color,
            AutomaticSize = Enum.AutomaticSize.X
        })

        local item_connection
        item_connection = RunService.RenderStepped:Connect(function()
            if not item or not item.Parent then
                item_folder:Destroy()
                item_connection:Disconnect()
                return
            end

            local root = getItemRoot(item)
            if root then
                local screen_pos, visible = Camera:WorldToViewportPoint(root.Position)
                local dist = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude) or 0

                if visible and dist <= esp_library.settings.item_esp.max_distance and esp_library.settings.item_esp.enabled then
                    label.Visible = true
                    label.Position = UDim2.new(0, screen_pos.X, 0, screen_pos.Y)
                    label.FontFace = get_font(esp_library.settings.item_esp.font)
                    label.TextColor3 = esp_library.settings.item_esp.color
                    
                    local text = ""
                    if esp_library.settings.item_esp.names then
                        text = item.Name
                    end
                    if esp_library.settings.item_esp.distance then
                        text = text .. (text ~= "" and " " or "") .. string.format('(<font color="rgb(150, 150, 150)">%d</font>)', math.floor(dist))
                    end
                    label.Text = text
                else
                    label.Visible = false
                end
            else
                label.Visible = false
            end
        end)
    end

    local items_folder = workspace:FindFirstChild("Items")
    if items_folder then
        for _, item in ipairs(items_folder:GetChildren()) do
            task.spawn(create_item_esp, item)
        end
        items_folder.ChildAdded:Connect(function(item)
            task.delay(0.1, function() create_item_esp(item) end)
        end)
    end
end

