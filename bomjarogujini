local function getItemRoot(itemModel)
    if not itemModel then return nil end
    local success, result = pcall(function()
        if itemModel:IsA("Model") then
            return itemModel.PrimaryPart or itemModel:FindFirstChildWhichIsA("BasePart")
        elseif itemModel:IsA("BasePart") then
            return itemModel
        end
        return itemModel:FindFirstChildWhichIsA("BasePart", true)
    end)
    return success and result or nil
end

