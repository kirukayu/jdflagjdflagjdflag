local function apply_domain_collision(obj, state)
    if not obj or not obj:IsA("Instance") then return end
    local function set_can_collide(o)
        if o:IsA("BasePart") then
            pcall(function() o.CanCollide = state end)
        end
        -- Also handle potential custom attributes
        pcall(function() o:SetAttribute("CanCollide", state) end)
    end
    set_can_collide(obj)
    for _, v in pairs(obj:GetDescendants()) do
        set_can_collide(v)
    end
end

local function set_all_domain_collisions(state)
    local domains_folder = workspace:FindFirstChild("Domains")
    if domains_folder then
        for _, domain in pairs(domains_folder:GetChildren()) do
            apply_domain_collision(domain, state)
        end
    end
end

