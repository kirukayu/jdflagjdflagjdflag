local function setupEnemyHitListeners()
    local Players = game:GetService("Players")
    local function setupListener(player)
        if player == LocalPlayer then return end
        local animConns = {}
        local function onCharacterAdded(char)
            for _, c in ipairs(animConns) do pcall(function() c:Disconnect() end) end
            table.clear(animConns)
            
            local hum = char:WaitForChild("Humanoid", 5)
            if hum then
                local lastHp = hum.Health
                local hConn = hum:GetPropertyChangedSignal("Health"):Connect(function()
                    if not AutoBlock.SoundBro then return end
                    local currentHp = hum.Health
                    if currentHp < lastHp then
                        if getgenv().OBLV_Used_FeverBreak and tick() - getgenv().OBLV_Used_FeverBreak < 1.2 then
                            local lpChar = LocalPlayer.Character
                            local hrpMe = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
                            local hrpEn = char:FindFirstChild("HumanoidRootPart")
                            if hrpMe and hrpEn and (hrpEn.Position - hrpMe.Position).Magnitude <= 15 then
                                if not getgenv().OBLV_Backshot_Tick or tick() - getgenv().OBLV_Backshot_Tick > 2.0 then
                                    getgenv().OBLV_Backshot_Tick = tick()
                                    task.spawn(function()
                                        if getgenv().OBLV_Audio then getgenv().OBLV_Audio.Play("backshot", 3.0) end
                                        task.wait(0.85)
                                        if getgenv().OBLV_Audio then getgenv().OBLV_Audio.Play("backshot", 3.0) end
                                    end)
                                end
                            end
                        end
                    end
                    lastHp = currentHp
                end)
                table.insert(animConns, hConn)
            end
            
            local animator = hum and hum:WaitForChild("Animator", 5)
            if animator then
                local conn = animator.AnimationPlayed:Connect(function(track)
                    if not AutoBlock.SoundMinecrafthit then return end

                    local lpChar = LocalPlayer.Character
                    local lpHrp = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    
                    if lpHrp and hrp and (hrp.Position - lpHrp.Position).Magnitude <= 10 then
                        local animId = track.Animation and track.Animation.AnimationId
                        local realId = getAssetId(animId)
                        
                        local animId = track.Animation and track.Animation.AnimationId
                        local realId = getAssetId(animId)
                        local fPath = (track.Animation and track.Animation:GetFullName() or ""):lower()
                        
                        -- CATCH-ALL: IF THIS ID IS ACTUALLY THE ENEMY'S VICTIM ANIMATION, INSTANT BACKSHOT:
                        if realId == 108123475959041 then
                            if not getgenv().OBLV_Backshot_Tick then getgenv().OBLV_Backshot_Tick = 0 end
                            if tick() - getgenv().OBLV_Backshot_Tick > 3 then
                                getgenv().OBLV_Backshot_Tick = tick()
                                if getgenv().OBLV_Audio then
                                    getgenv().OBLV_Audio.Play("backshot", 3.0)
                                end
                            end
                            return
                        end
                        
                        if getgenv().OBLV_Doing_Backshot and tick() - getgenv().OBLV_Doing_Backshot < 5 then
                            -- Any non-movement animation within 10 studs during a grab = Victim Caught!
                            if not string.find(fPath, "idle") and not string.find(fPath, "walk") and not string.find(fPath, "run") and not string.find(fPath, "dash") then
                                if not getgenv().OBLV_Backshot_Tick then getgenv().OBLV_Backshot_Tick = 0 end
                                if tick() - getgenv().OBLV_Backshot_Tick > 0.05 then
                                    getgenv().OBLV_Backshot_Tick = tick()
                                    if getgenv().OBLV_Audio then
                                        getgenv().OBLV_Audio.Play("backshot", 3.0)
                                    end
                                end
                            end
                        else
                            -- NORMAL HIT LOGIC
                            if realId and normalHitAnimations[realId] then
                                local len = track.Length
                                if len > 0.1 and len < 0.6 then
                                    if not getgenv().OBLV_Minecrafthit_Lock then
                                        getgenv().OBLV_Minecrafthit_Lock = true
                                        
                                        if getgenv().OBLV_Audio then
                                            getgenv().OBLV_Audio.Play("minecrafthit", 2.0)
                                        end
                                        
                                        task.delay(0.2, function()
                                            getgenv().OBLV_Minecrafthit_Lock = false
                                        end)
                                    end
                                end
                            end
                        end
                    end
                end)
                table.insert(animConns, conn)
            end
        end
        player.CharacterAdded:Connect(onCharacterAdded)
        if player.Character then task.spawn(onCharacterAdded, player.Character) end
    end

    for _, p in ipairs(Players:GetPlayers()) do setupListener(p) end
    Players.PlayerAdded:Connect(setupListener)
end

